<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Kataka.App.App"
             xmlns:local="using:Kataka.App"
             xmlns:controls="using:Kataka.App.Controls"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>

            <!-- ── Surfaces (by depth) ─────────────────────────────────────── -->
            <Color x:Key="BgBase">#111317</Color>
            <Color x:Key="BgSurface">#1A1D22</Color>
            <Color x:Key="BgElevated">#272B31</Color>
            <Color x:Key="BgContrast">#0D0F12</Color>

            <!-- ── Brand accent ─────────────────────────────────────────────── -->
            <Color x:Key="Primary">#FFB741</Color>
            <Color x:Key="PrimaryLit">#FFCF66</Color>

            <!-- ── Semantic status ─────────────────────────────────────────── -->
            <Color x:Key="Success">#3DBF6C</Color>
            <Color x:Key="Error">#E05050</Color>
            <Color x:Key="LedOn">#00E676</Color>
            <Color x:Key="LedOff">#333333</Color>

            <!-- ── Text ────────────────────────────────────────────────────── -->
            <Color x:Key="TextMain">#F2EEE3</Color>
            <Color x:Key="TextMuted">#7A8494</Color>

            <!-- ── Borders ─────────────────────────────────────────────────── -->
            <Color x:Key="Border">#3A3F47</Color>
            <Color x:Key="BorderLight">#565B64</Color>

            <!-- ── Brushes ──────────────────────────────────────────────────── -->
            <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}" />
            <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}" />
            <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}" />
            <SolidColorBrush x:Key="BgContrastBrush" Color="{StaticResource BgContrast}" />
            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
            <SolidColorBrush x:Key="PrimaryLitBrush" Color="{StaticResource PrimaryLit}" />
            <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}" />
            <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource Error}" />
            <SolidColorBrush x:Key="LedOnBrush" Color="{StaticResource LedOn}" />
            <SolidColorBrush x:Key="LedOffBrush" Color="{StaticResource LedOff}" />
            <SolidColorBrush x:Key="TextMainBrush" Color="{StaticResource TextMain}" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
            <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}" />
            <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLight}" />

            <!-- ── Compat aliases (used in view files — keep until migrated) ── -->
            <Color x:Key="ColorCardBgTop">#2E3138</Color>
            <Color x:Key="ColorCardBgBottom">#1C1F24</Color>
            <SolidColorBrush x:Key="KatanaAccentBrush" Color="{StaticResource Primary}" />
            <SolidColorBrush x:Key="KatanaSubtleTextBrush" Color="{StaticResource TextMuted}" />
            <SolidColorBrush x:Key="TextLightBrush" Color="#F1F1F1" />

        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <Style Selector="Window">
            <Setter Property="Background" Value="{StaticResource BgBaseBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="FontFamily" Value="{x:Static controls:KatanaPalette.AppFont}" />
        </Style>

        <Style Selector="Border.transport-shell">
            <Setter Property="Background" Value="{StaticResource BgSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>

        <Style Selector="Border.amp-shell">
            <Setter Property="Background" Value="{StaticResource BgBaseBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
        </Style>

        <Style Selector="Border.panel-section">
            <Setter Property="Background" Value="{StaticResource BgSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style Selector="Border.panel-section.alt">
            <Setter Property="Background" Value="{StaticResource BgElevatedBrush}" />
        </Style>

        <Style Selector="Button.transport-button">
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Background" Value="{StaticResource BgElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
        </Style>

        <Style Selector="Button.transport-button.accent">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryLitBrush}" />
            <Setter Property="Foreground" Value="{StaticResource BgBaseBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="ToggleButton.channel-button:checked">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryLitBrush}" />
            <Setter Property="Foreground" Value="{StaticResource BgBaseBrush}" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style Selector="ToggleButton.effect-button">
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="Background" Value="{StaticResource BgElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="MinWidth" Value="96" />
        </Style>

        <Style Selector="ToggleButton.effect-button:checked">
            <Setter Property="Background" Value="{StaticResource PrimaryLitBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryLitBrush}" />
            <Setter Property="Foreground" Value="{StaticResource BgBaseBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBox.diagnostic-log">
            <Setter Property="Background" Value="{StaticResource BgContrastBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
        </Style>

        <Style Selector="Border.stompbox-card">
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Border.stompbox-card.selected">
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryLitBrush}" />
        </Style>

        <!-- ── ComboBox: pedal type picker ─────────────────────────────────── -->
        <Style Selector="ComboBox.pedal-type-picker">
            <Setter Property="Background" Value="{StaticResource BgElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,0,4,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="MaxDropDownHeight" Value="280" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel>
                        <Border Name="Background"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                MinHeight="{TemplateBinding MinHeight}">
                            <Grid ColumnDefinitions="*,Auto">
                                <ContentPresenter Name="ContentPresenter"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  Margin="{TemplateBinding Padding}"
                                                  Foreground="{TemplateBinding Foreground}"
                                                  FontSize="{TemplateBinding FontSize}" />
                                <Path Grid.Column="1"
                                      Data="M0,0 L5,5 L10,0"
                                      Stroke="{StaticResource PrimaryBrush}"
                                      StrokeThickness="1.5"
                                      Fill="Transparent"
                                      Width="10" Height="6"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="4,0,10,0"
                                      IsHitTestVisible="False" />
                            </Grid>
                        </Border>
                        <Popup Name="PART_Popup"
                               IsLightDismissEnabled="True"
                               IsOpen="{TemplateBinding IsDropDownOpen, Mode=TwoWay}"
                               MaxHeight="{TemplateBinding MaxDropDownHeight}"
                               PlacementTarget="{TemplateBinding}"
                               Placement="BottomEdgeAlignedLeft"
                               WindowManagerAddShadowHint="False">
                            <Border Name="PopupBorder"
                                    Background="{StaticResource BgElevatedBrush}"
                                    BorderBrush="{StaticResource BorderLightBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="3">
                                <ScrollViewer>
                                    <ItemsPresenter Name="PART_ItemsPresenter"
                                                    ItemsPanel="{TemplateBinding ItemsPanel}" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Panel>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="ComboBox.pedal-type-picker:pointerover /template/ Border#Background">
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
        </Style>

        <Style Selector="ComboBox.pedal-type-picker:focus /template/ Border#Background">
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryLitBrush}" />
        </Style>

        <Style Selector="ComboBox.pedal-type-picker[IsDropDownOpen=True] /template/ Border#Background">
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryLitBrush}" />
        </Style>

        <Style Selector="ComboBox.pedal-type-picker ComboBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style Selector="ComboBox.pedal-type-picker ComboBoxItem:pointerover">
            <Setter Property="Background" Value="{StaticResource BgContrastBrush}" />
        </Style>

        <Style Selector="ComboBox.pedal-type-picker ComboBoxItem:selected">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="{StaticResource BgBaseBrush}" />
        </Style>

        <Style Selector="ComboBox.pedal-type-picker ComboBoxItem:selected:pointerover">
            <Setter Property="Background" Value="{StaticResource PrimaryLitBrush}" />
        </Style>

    </Application.Styles>
</Application>
