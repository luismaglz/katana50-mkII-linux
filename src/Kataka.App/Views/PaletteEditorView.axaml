<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Kataka.App.Views.PaletteEditorView"
             x:DataType="vm:PaletteEditorViewModel"
             x:CompileBindings="False">

    <Expander Header="PALETTE EDITOR"
              IsExpanded="False"
              Padding="0">

        <WrapPanel Orientation="Horizontal"
                   Margin="4,8,4,4"
                   ItemWidth="200">

            <!-- Accent -->
            <StackPanel Margin="6,0,6,8"
                        Spacing="4">
                <TextBlock Text="ACCENT"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource KatanaSubtleTextBrush}" />
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="6">
                    <TextBox Text="{Binding AccentHex}"
                             FontFamily="Monospace"
                             FontSize="12"
                             Padding="6,4" />
                    <Border Grid.Column="1"
                            Width="28"
                            Height="28"
                            CornerRadius="4"
                            Background="{Binding AccentSwatch}" />
                </Grid>
            </StackPanel>

            <!-- Knob Face -->
            <StackPanel Margin="6,0,6,8"
                        Spacing="4">
                <TextBlock Text="KNOB FACE"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource KatanaSubtleTextBrush}" />
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="6">
                    <TextBox Text="{Binding KnobFaceHex}"
                             FontFamily="Monospace"
                             FontSize="12"
                             Padding="6,4" />
                    <Border Grid.Column="1"
                            Width="28"
                            Height="28"
                            CornerRadius="4"
                            Background="{Binding KnobFaceSwatch}" />
                </Grid>
            </StackPanel>

            <!-- Bg Base -->
            <StackPanel Margin="6,0,6,8"
                        Spacing="4">
                <TextBlock Text="BG BASE"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource KatanaSubtleTextBrush}" />
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="6">
                    <TextBox Text="{Binding BgBaseHex}"
                             FontFamily="Monospace"
                             FontSize="12"
                             Padding="6,4" />
                    <Border Grid.Column="1"
                            Width="28"
                            Height="28"
                            CornerRadius="4"
                            Background="{Binding BgBaseSwatch}" />
                </Grid>
            </StackPanel>

            <!-- Bg Surface -->
            <StackPanel Margin="6,0,6,8"
                        Spacing="4">
                <TextBlock Text="BG SURFACE"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource KatanaSubtleTextBrush}" />
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="6">
                    <TextBox Text="{Binding BgSurfaceHex}"
                             FontFamily="Monospace"
                             FontSize="12"
                             Padding="6,4" />
                    <Border Grid.Column="1"
                            Width="28"
                            Height="28"
                            CornerRadius="4"
                            Background="{Binding BgSurfaceSwatch}" />
                </Grid>
            </StackPanel>

            <!-- Bg Elevated -->
            <StackPanel Margin="6,0,6,8"
                        Spacing="4">
                <TextBlock Text="BG ELEVATED"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource KatanaSubtleTextBrush}" />
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="6">
                    <TextBox Text="{Binding BgElevatedHex}"
                             FontFamily="Monospace"
                             FontSize="12"
                             Padding="6,4" />
                    <Border Grid.Column="1"
                            Width="28"
                            Height="28"
                            CornerRadius="4"
                            Background="{Binding BgElevatedSwatch}" />
                </Grid>
            </StackPanel>

        </WrapPanel>
    </Expander>
</UserControl>
