<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Kataka.App.Views.GlobalEqView"
             x:DataType="vm:GlobalEqViewModel"
             x:CompileBindings="False">

    <StackPanel Spacing="6">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <CheckBox Content="EQ On" IsChecked="{Binding IsOn}" />
            <ComboBox SelectedIndex="{Binding Type}" Width="160">
                <ComboBoxItem Content="Parametric" />
                <ComboBoxItem Content="Graphic EQ" />
            </ComboBox>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
            <controls:EqBandSlider Label="31" Minimum="0" Maximum="40" Value="{Binding GraphicEq31Hz}" Scale="0.9" />
            <controls:EqBandSlider Label="62" Minimum="0" Maximum="40" Value="{Binding GraphicEq62Hz}" Scale="0.9" />
            <controls:EqBandSlider Label="125" Minimum="0" Maximum="40" Value="{Binding GraphicEq125Hz}" Scale="0.9" />
            <controls:EqBandSlider Label="250" Minimum="0" Maximum="40" Value="{Binding GraphicEq250Hz}" Scale="0.9" />
            <controls:EqBandSlider Label="500" Minimum="0" Maximum="40" Value="{Binding GraphicEq500Hz}" Scale="0.9" />
            <controls:EqBandSlider Label="1k" Minimum="0" Maximum="40" Value="{Binding GraphicEq1kHz}" Scale="0.9" />
            <controls:EqBandSlider Label="2k" Minimum="0" Maximum="40" Value="{Binding GraphicEq2kHz}" Scale="0.9" />
            <controls:EqBandSlider Label="4k" Minimum="0" Maximum="40" Value="{Binding GraphicEq4kHz}" Scale="0.9" />
            <controls:EqBandSlider Label="8k" Minimum="0" Maximum="40" Value="{Binding GraphicEq8kHz}" Scale="0.9" />
            <controls:EqBandSlider Label="16k" Minimum="0" Maximum="40" Value="{Binding GraphicEq16kHz}" Scale="0.9" />
            <controls:EqBandSlider Label="LVL" Minimum="0" Maximum="40" Value="{Binding GraphicEqLevel}" Scale="0.9" />
        </StackPanel>
    </StackPanel>
</UserControl>