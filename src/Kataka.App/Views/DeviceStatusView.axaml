<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{x:Static dvm:DesignMainWindowViewModel.Instance}"
             x:Class="Kataka.App.Views.DeviceStatusView"
             x:DataType="vm:MainWindowViewModel">

    <StackPanel Spacing="14">
        <Border Classes="panel-section alt" Padding="16">
            <StackPanel Spacing="10">
                <TextBlock Text="DEVICE" FontSize="16" FontWeight="Bold" LetterSpacing="1.5" />
                <TextBlock Text="MIDI identity request to confirm the connected amp."
                           TextWrapping="Wrap" FontSize="11"
                           Foreground="{StaticResource KatanaSubtleTextBrush}" />
                <Button Classes="transport-button accent" Content="Request identity"
                        HorizontalAlignment="Left" Command="{Binding MidiConnection.RequestIdentityCommand}" />
                <TextBlock Text="IDENTITY REPLY" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource KatanaSubtleTextBrush}" />
                <TextBlock Text="{Binding MidiConnection.IdentityReply}" TextWrapping="Wrap" FontSize="11" />
            </StackPanel>
        </Border>
        <Border Classes="panel-section" Padding="16">
            <StackPanel Spacing="8">
                <TextBlock Text="LIVE STATUS" FontSize="16" FontWeight="Bold"
                           LetterSpacing="1.5" />
                <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding MidiConnection.DetectionMessage}" TextWrapping="Wrap" FontSize="11"
                           Foreground="{StaticResource KatanaSubtleTextBrush}" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
