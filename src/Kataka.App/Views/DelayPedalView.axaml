<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="300"
             d:DesignHeight="520"
             d:DataContext="{x:Static dvm:DesignDelayPedalViewModel.Instance}"
             x:Class="Kataka.App.Views.DelayPedalView"
             x:DataType="vm:DelayPedalViewModel">

    <Border MinWidth="160" CornerRadius="8" VerticalAlignment="Top">
        <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Offset="0" Color="#2e3138" />
                <GradientStop Offset="1" Color="#1c1f24" />
            </LinearGradientBrush>
        </Border.Background>
        <StackPanel Spacing="0">
            <!-- Delay accent bar: cyan -->
            <Border Height="6" CornerRadius="8,8,0,0" Background="#30cfc0" />
            <StackPanel Spacing="10" Margin="12,10,12,14">
                <!-- On/Off toggle + LED -->
                <controls:PedalHeaderControl />

                <!-- Type selector -->
                <StackPanel Spacing="4">
                    <TextBlock Text="TYPE" FontSize="10" FontWeight="SemiBold"
                               Foreground="#1e9988" />
                    <ComboBox Classes="midi-port-picker"
                              HorizontalAlignment="Stretch"
                              ItemsSource="{Binding TypeOptions}"
                              SelectedItem="{Binding SelectedTypeOption}" />
                </StackPanel>

                <!-- Row 1: Feedback, HiCut, E.Level, D.Mix -->
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <controls:SmallImageRotaryKnob  Label="FEEDBACK"
                                                    Description="Adjusts the volume returned to the input. Higher values increase the number of delay repeats."
                                                    Minimum="0" Maximum="100"
                                                    Value="{Binding Feedback}"
                                                    LabelFontSize="12" />
                    <controls:SmallImageRotaryKnob  Label="HI CUT"
                                                    Description="Sets the frequency at which the high cut filter takes effect. At maximum (FLAT), the filter has no effect."
                                                    Minimum="0" Maximum="14"
                                                    Value="{Binding HighCut}"
                                                    LabelFontSize="12" />
                    <controls:SmallImageRotaryKnob  Label="E.LEVEL"
                                                    Description="Adjusts the volume of the delay (effect) sound."
                                                    Minimum="0" Maximum="120"
                                                    Value="{Binding EffectLevel}"
                                                    LabelFontSize="12" />
                    <controls:SmallImageRotaryKnob  Label="D.MIX"
                                                    Description="Adjusts the volume of the direct (dry) sound."
                                                    Minimum="0" Maximum="100"
                                                    Value="{Binding DirectMix}"
                                                    LabelFontSize="12" />
                </StackPanel>

                <!-- Row 2: TapTime, ModRate, ModDepth -->
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <controls:SmallImageRotaryKnob  Label="TAP TIME"
                                                    Description="Adjusts the delay time of the right channel relative to the left channel (100%). Only active when TYPE is PAN."
                                                    Minimum="0" Maximum="100"
                                                    Value="{Binding TapTime}"
                                                    LabelFontSize="12" />
                    <controls:SmallImageRotaryKnob  Label="MOD RATE"
                                                    Description="Adjusts the modulation rate of the delay sound. Only active when TYPE is MODULATE or SDE-3000."
                                                    Minimum="0" Maximum="100"
                                                    Value="{Binding ModRate}"
                                                    LabelFontSize="12" />
                    <controls:SmallImageRotaryKnob  Label="MOD DEPTH"
                                                    Description="Adjusts the modulation depth of the delay sound. Only active when TYPE is MODULATE or SDE-3000."
                                                    Minimum="0" Maximum="100"
                                                    Value="{Binding ModDepth}"
                                                    LabelFontSize="12" />
                </StackPanel>

                <!-- Toggles row 1: Range, Filter, ModSw -->
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="8">
                    <ToggleButton Classes="effect-button"
                                  Content="17kHz"
                                  Width="72"
                                  IsChecked="{Binding RangeHigh}" />
                    <ToggleButton Classes="effect-button"
                                  Content="FILTER"
                                  Width="72"
                                  IsChecked="{Binding FilterOn}" />
                    <ToggleButton Classes="effect-button"
                                  Content="MOD SW"
                                  Width="72"
                                  IsChecked="{Binding ModSwOn}" />
                </StackPanel>

                <!-- Toggles row 2: FeedbackPhase (INV), DelayPhase (INV) -->
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="8">
                    <ToggleButton Classes="effect-button"
                                  Content="FB INV"
                                  Width="110"
                                  IsChecked="{Binding FeedbackPhaseInverse}" />
                    <ToggleButton Classes="effect-button"
                                  Content="DLY INV"
                                  Width="110"
                                  IsChecked="{Binding DelayPhaseInverse}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
