<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:views="using:Kataka.App.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1100"
             d:DesignHeight="480"
             d:DataContext="{x:Static dvm:DesignMainWindowViewModel.Instance}"
             x:Class="Kataka.App.Views.PedalboardView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="panel-section alt" Padding="18">
        <StackPanel Spacing="12">
            <TextBlock Text="PEDALBOARD"
                       FontSize="18" FontWeight="Bold" LetterSpacing="1.5" />

            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Pedalboard.PedalboardItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Top" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PedalboardItemViewModel">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Top">

                                <!-- Signal cable between items -->
                                <Canvas IsVisible="{Binding IsConnectedFromPrevious}"
                                        Width="28" Height="40" VerticalAlignment="Top" Margin="0,24,0,0">
                                    <Border Canvas.Left="0" Canvas.Top="14" Width="28" Height="4"
                                            CornerRadius="2" Background="#7a7060" />
                                    <Border Canvas.Left="0" Canvas.Top="12" Width="7" Height="8"
                                            CornerRadius="2" Background="#444" />
                                    <Border Canvas.Left="21" Canvas.Top="12" Width="7" Height="8"
                                            CornerRadius="2" Background="#444" />
                                </Canvas>

                                <!-- ── INPUT / OUTPUT pill ── -->
                                <Border IsVisible="{Binding IsEndpoint}"
                                        CornerRadius="20" Width="80"
                                        Padding="10,14"
                                        BorderThickness="2"
                                        BorderBrush="#3a5a6a"
                                        Background="#111c26"
                                        VerticalAlignment="Top">
                                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="11" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#7ab0c8" LetterSpacing="1.2" />
                                        <TextBlock Text="{Binding Detail}"
                                                   FontSize="9" HorizontalAlignment="Center"
                                                   TextWrapping="Wrap" TextAlignment="Center"
                                                   Foreground="#3a6070" />
                                    </StackPanel>
                                </Border>

                                <!-- ── AMP block ── -->
                                <Border IsVisible="{Binding IsAmp}"
                                        Width="110" CornerRadius="3,3,12,12"
                                        BorderThickness="2" BorderBrush="#8b1c1c"
                                        Background="#1e0c0c" VerticalAlignment="Top">
                                    <StackPanel Spacing="0">
                                        <Border Height="6" CornerRadius="3,3,0,0"
                                                Background="{Binding FamilyAccentColor}" />
                                        <StackPanel Spacing="5" Margin="10,10,10,12" HorizontalAlignment="Center">
                                            <TextBlock Text="▣" FontSize="20"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#c0392b" />
                                            <TextBlock Text="AMP" FontSize="13" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#e04040" LetterSpacing="2" />
                                            <TextBlock Text="{Binding Detail}"
                                                       FontSize="10" HorizontalAlignment="Center"
                                                       Foreground="#7a4040" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ── Booster pedal ── -->
                                <Panel IsVisible="{Binding IsBooster}">
                                    <views:BoosterPedalView DataContext="{Binding BoosterPedal}" />
                                </Panel>

                                <!-- ── Mod pedal ── -->
                                <Panel IsVisible="{Binding IsMod}">
                                    <views:ModPedalView DataContext="{Binding ModPedal}" />
                                </Panel>

                                <!-- ── FX pedal ── -->
                                <Panel IsVisible="{Binding IsFx}">
                                    <views:FxPedalView DataContext="{Binding FxPedal}" />
                                </Panel>

                                <!-- ── Delay pedal (covers delay + delay2) ── -->
                                <Panel IsVisible="{Binding IsDelay}">
                                    <views:DelayPedalView DataContext="{Binding DelayPedal}" />
                                </Panel>

                                <!-- ── Reverb pedal ── -->
                                <Panel IsVisible="{Binding IsReverb}">
                                    <views:ReverbPedalView DataContext="{Binding ReverbPedal}" />
                                </Panel>

                                <!-- ── Pedal FX card ── -->
                                <Border IsVisible="{Binding IsPedalFx}"
                                        Width="320" CornerRadius="8"
                                        VerticalAlignment="Top">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                            <GradientStop Offset="0" Color="#2e3138" />
                                            <GradientStop Offset="1" Color="#1c1f24" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel Spacing="0">
                                        <Border Height="6" CornerRadius="8,8,0,0" Background="#e85c1a" />
                                        <StackPanel Spacing="10" Margin="12,10,12,14">
                                            <!-- On/Off -->
                                            <ToggleButton Classes="effect-button"
                                                          HorizontalAlignment="Stretch"
                                                          Content="PEDAL FX"
                                                          IsChecked="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.IsEnabled}" />
                                            <!-- Type + Position row -->
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="TYPE" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                                    <ComboBox Classes="midi-port-picker"
                                                              HorizontalAlignment="Stretch"
                                                              ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.TypeOptions}"
                                                              SelectedItem="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.SelectedTypeOption}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <TextBlock Text="POSITION" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                                    <ComboBox Classes="midi-port-picker"
                                                              HorizontalAlignment="Stretch"
                                                              ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.PositionOptions}"
                                                              SelectedItem="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.SelectedPositionOption}" />
                                                </StackPanel>
                                            </Grid>
                                            <!-- Foot volume -->
                                            <StackPanel Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="FOOT VOL" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{StaticResource KatanaSubtleTextBrush}"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.FootVolume}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource KatanaSubtleTextBrush}"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                                <Slider Minimum="0" Maximum="100"
                                                        Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.FootVolume}"
                                                        HorizontalAlignment="Stretch" />
                                            </StackPanel>
                                            <!-- Wah sub-controls -->
                                            <StackPanel IsVisible="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.IsWahMode}"
                                                        Spacing="6">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="WAH TYPE" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                                    <ComboBox Classes="midi-port-picker"
                                                              HorizontalAlignment="Stretch"
                                                              ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.WahTypeOptions}"
                                                              SelectedItem="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.SelectedWahTypeOption}" />
                                                </StackPanel>
                                                <UniformGrid Columns="2" ColumnSpacing="4" RowSpacing="4">
                                                    <controls:RotaryKnob Label="Position" Minimum="0" Maximum="100"
                                                                         Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.PedalPosition}" />
                                                    <controls:RotaryKnob Label="Min" Minimum="0" Maximum="100"
                                                                         Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.PedalMinimum}" />
                                                    <controls:RotaryKnob Label="Max" Minimum="0" Maximum="100"
                                                                         Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.PedalMaximum}" />
                                                    <controls:RotaryKnob Label="Level" Minimum="0" Maximum="100"
                                                                         Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.EffectLevel}" />
                                                    <controls:RotaryKnob Label="Mix" Minimum="0" Maximum="100"
                                                                         Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.DirectMix}" />
                                                </UniformGrid>
                                            </StackPanel>
                                            <!-- Pedal Bend sub-controls -->
                                            <StackPanel IsVisible="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.IsBendMode}"
                                                        Spacing="4">
                                                <UniformGrid Columns="2" ColumnSpacing="4" RowSpacing="4">
                                                    <controls:RotaryKnob Label="Pitch" Minimum="-24" Maximum="24"
                                                                         Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.BendPitch}" />
                                                    <controls:RotaryKnob Label="Position" Minimum="0" Maximum="100"
                                                                         Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.BendPosition}" />
                                                    <controls:RotaryKnob Label="Level" Minimum="0" Maximum="100"
                                                                         Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.BendEffectLevel}" />
                                                    <controls:RotaryKnob Label="Mix" Minimum="0" Maximum="100"
                                                                         Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.BendDirectMix}" />
                                                </UniformGrid>
                                            </StackPanel>
                                            <!-- EVH95 sub-controls -->
                                            <StackPanel IsVisible="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.IsEvh95Mode}"
                                                        Spacing="4">
                                                <UniformGrid Columns="2" ColumnSpacing="4" RowSpacing="4">
                                                    <controls:RotaryKnob Label="Position" Minimum="0" Maximum="100"
                                                                         Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.Evh95Position}" />
                                                    <controls:RotaryKnob Label="Min" Minimum="0" Maximum="100"
                                                                         Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.Evh95Minimum}" />
                                                    <controls:RotaryKnob Label="Max" Minimum="0" Maximum="100"
                                                                         Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.Evh95Maximum}" />
                                                    <controls:RotaryKnob Label="Level" Minimum="0" Maximum="100"
                                                                         Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.Evh95EffectLevel}" />
                                                    <controls:RotaryKnob Label="Mix" Minimum="0" Maximum="100"
                                                                         Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).PedalFx.Evh95DirectMix}" />
                                                </UniformGrid>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Border>
</UserControl>
