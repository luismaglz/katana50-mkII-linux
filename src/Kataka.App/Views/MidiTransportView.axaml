<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Kataka.App.Views.MidiTransportView"
             x:DataType="vm:MainWindowViewModel">

    <Border Classes="transport-shell" Padding="18">
        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="18" RowSpacing="12">
            <StackPanel Grid.RowSpan="2" Spacing="4">
                <TextBlock Text="KATAKA"
                           FontSize="28"
                           FontWeight="Bold"
                           LetterSpacing="3" />
                <TextBlock Text="Linux-first Katana amp editor"
                           Foreground="{StaticResource KatanaSubtleTextBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="MIDI INPUT"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource KatanaSubtleTextBrush}" />
                    <ComboBox Classes="midi-port-picker"
                              ItemsSource="{Binding MidiConnection.InputPorts}"
                              SelectedItem="{Binding MidiConnection.SelectedInputPort}" />
                </StackPanel>
                <StackPanel Spacing="6">
                    <TextBlock Text="MIDI OUTPUT"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource KatanaSubtleTextBrush}" />
                    <ComboBox Classes="midi-port-picker"
                              ItemsSource="{Binding MidiConnection.OutputPorts}"
                              SelectedItem="{Binding MidiConnection.SelectedOutputPort}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Top">
                <Button Classes="transport-button"
                        Content="Scan"
                        Command="{Binding MidiConnection.ScanCommand}" />
                <Button Classes="transport-button accent"
                        Content="Connect"
                        Command="{Binding MidiConnection.ConnectCommand}" />
                <Button Classes="transport-button"
                        Content="Disconnect"
                        Command="{Binding MidiConnection.DisconnectCommand}" />
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                <TextBlock Text="{Binding StatusMessage}"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding MidiConnection.DetectionMessage}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource KatanaSubtleTextBrush}" />
            </StackPanel>

            <TextBlock Grid.Row="2"
                       Grid.Column="1"
                       Grid.ColumnSpan="2"
                       Text="Read sync controls targeted read-back after writes. Write sync queues knob and toggle edits and flushes them automatically."
                       Foreground="{StaticResource KatanaSubtleTextBrush}"
                       TextWrapping="Wrap" />
        </Grid>
    </Border>
</UserControl>
