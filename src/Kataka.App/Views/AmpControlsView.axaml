<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:views="using:Kataka.App.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{x:Static dvm:DesignAmpEditorViewModel.Instance}"
             x:Class="Kataka.App.Views.AmpControlsView"
             x:DataType="vm:AmpEditorViewModel"
             x:CompileBindings="False">

    <Border Classes="panel-section" Padding="16 16 16 0" MinWidth="340">
        <StackPanel>
            <views:PanelView DataContext="{Binding Panel}" />

            <StackPanel Orientation="Horizontal" Margin="20 0 0 0" VerticalAlignment="Bottom">
                <ToggleButton IsChecked="{Binding IsAmpVariation}"
                              Classes="effect-toggle"
                              Content="VARIATION"
                              ToolTip.Tip="Amp Variation (TYPE 1 / TYPE 2)" />
                <views:ChannelSelectionView DataContext="{Binding ChannelSelection}" />

            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
