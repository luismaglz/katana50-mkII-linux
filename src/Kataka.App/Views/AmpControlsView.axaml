<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:views="using:Kataka.App.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{x:Static dvm:DesignAmpEditorViewModel.Instance}"
             x:Class="Kataka.App.Views.AmpControlsView"
             x:DataType="vm:AmpEditorViewModel">

    <Border Classes="panel-section" Padding="16" MinWidth="340">
        <StackPanel Spacing="10">
            <ItemsControl ItemsSource="{Binding AmpControls}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" ItemSpacing="14" LineSpacing="14" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:AmpControlViewModel">
                        <controls:RotaryKnob Label="{Binding DisplayName}"
                                             Minimum="{Binding Minimum}"
                                             Maximum="{Binding Maximum}"
                                             Value="{Binding Value}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <views:PanelView DataContext="{Binding Panel}" />
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <StackPanel Spacing="4">
                    <TextBlock Text="AMP TYPE" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource KatanaSubtleTextBrush}" />
                    <ComboBox Classes="midi-port-picker" HorizontalAlignment="Stretch"
                              ItemsSource="{x:Static vm:AmpEditorViewModel.AmpTypeOptions}"
                              SelectedItem="{Binding SelectedAmpType}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                    <ToggleButton IsChecked="{Binding IsAmpVariation}"
                                  Classes="effect-toggle"
                                  Content="VARIATION"
                                  ToolTip.Tip="Amp Variation (TYPE 1 / TYPE 2)" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="CABINET" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource KatanaSubtleTextBrush}" />
                    <ComboBox Classes="midi-port-picker" HorizontalAlignment="Stretch"
                              ItemsSource="{x:Static vm:AmpEditorViewModel.CabinetResonanceOptions}"
                              SelectedItem="{Binding SelectedCabinetResonance}" />
                </StackPanel>
            </Grid>

        </StackPanel>
    </Border>
</UserControl>
