<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="300"
             d:DesignHeight="440"
             d:DataContext="{x:Static dvm:DesignBoosterPedalViewModel.Instance}"
             x:Class="Kataka.App.Views.BoosterPedalView"
             x:DataType="vm:BoosterPedalViewModel">

    <Border MinWidth="160" CornerRadius="8" VerticalAlignment="Top">
        <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Offset="0" Color="#2e3138" />
                <GradientStop Offset="1" Color="#1c1f24" />
            </LinearGradientBrush>
        </Border.Background>
        <StackPanel Spacing="0">
            <!-- Booster accent bar: amber -->
            <Border Height="6" CornerRadius="8,8,0,0" Background="#e8960a" />
            <StackPanel Spacing="10" Margin="12,10,12,14">
                <!-- On/Off toggle + LED -->
                <controls:PedalHeaderControl />
                <!-- Type selector -->
                <StackPanel Spacing="4">
                    <TextBlock Text="TYPE" FontSize="10" FontWeight="SemiBold"
                               Foreground="#907030" />
                    <ComboBox Classes="midi-port-picker"
                              HorizontalAlignment="Stretch"
                              ItemsSource="{Binding TypeOptions}"
                              SelectedItem="{Binding SelectedTypeOption}" />
                </StackPanel>
                <!-- Variation color -->
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">

                    <controls:RotaryKnob Scale="0.6" Label="DRIVE"
                                         Minimum="0" Maximum="120"
                                         Value="{Binding Drive}"
                                         LabelFontSize="12"/>
                    <controls:RotaryKnob Scale="0.6" Label="TONE"
                                         Minimum="0" Maximum="100"
                                         DisplayMinimum="-50" DisplayMaximum="50"
                                         Value="{Binding Tone}"
                                         LabelFontSize="12"/>

                </StackPanel>
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <controls:RotaryKnob Scale="0.6" Label="E.LEVEL"
                                         Minimum="0" Maximum="100"
                                         Value="{Binding EffectLevel}"
                                         LabelFontSize="12"/>
                    <controls:RotaryKnob Scale="0.6" Label="BOTTOM"
                                         Minimum="0" Maximum="100"
                                         DisplayMinimum="-50" DisplayMaximum="50"
                                         Value="{Binding Bottom}"
                                         LabelFontSize="12"/>
                    <controls:RotaryKnob Scale="0.6" Label="D.MIX"
                                         Minimum="0" Maximum="100"
                                         Value="{Binding DirectMix}"
                                         LabelFontSize="12"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="30">
                    <ToggleButton Classes="effect-button"
                                  HorizontalAlignment="Center"
                                  HorizontalContentAlignment="Center"
                                  VerticalAlignment="Center"
                                  Content="SOLO"
                                  Width="100"
                                  IsChecked="{Binding SoloSw}" />
                    <controls:RotaryKnob Scale="0.6" Label="SOLO LVL"
                                         Minimum="0" Maximum="100"
                                         Value="{Binding SoloLevel}"
                                         LabelFontSize="12"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
