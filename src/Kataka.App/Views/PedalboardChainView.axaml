<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1100"
             d:DesignHeight="160"
             d:DataContext="{x:Static dvm:DesignMainWindowViewModel.Instance}"
             x:Class="Kataka.App.Views.PedalboardChainView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="panel-section alt" Padding="18">
        <StackPanel Spacing="14">
            <StackPanel Spacing="4">
                <TextBlock Text="PEDALBOARD CHAIN"
                           FontSize="18" FontWeight="Bold" LetterSpacing="1.5" />
                <TextBlock Text="A stompbox-style chain overview of the currently surfaced blocks. Pedal FX moves before or after the amp according to its chain-position setting."
                           Foreground="{StaticResource KatanaSubtleTextBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Pedalboard.PedalboardItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PedalboardItemViewModel">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                <!-- Signal cable -->
                                <Canvas IsVisible="{Binding IsConnectedFromPrevious}"
                                        Width="32" Height="24" VerticalAlignment="Center">
                                    <Border Canvas.Left="0" Canvas.Top="10" Width="32" Height="4"
                                            CornerRadius="2" Background="#7a7060" />
                                    <Border Canvas.Left="0" Canvas.Top="8" Width="7" Height="8"
                                            CornerRadius="2" Background="#444" />
                                    <Border Canvas.Left="25" Canvas.Top="8" Width="7" Height="8"
                                            CornerRadius="2" Background="#444" />
                                </Canvas>

                                <!-- INPUT / OUTPUT pill node -->
                                <Border IsVisible="{Binding IsEndpoint}"
                                        CornerRadius="20" MinWidth="68" Padding="10,8"
                                        BorderThickness="2" BorderBrush="#3a5a6a"
                                        Background="#111c26">
                                    <StackPanel Spacing="2" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="10" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#7ab0c8" LetterSpacing="1.2" />
                                        <TextBlock Text="{Binding Detail}"
                                                   FontSize="9" HorizontalAlignment="Center"
                                                   Foreground="#3a5a6a" />
                                    </StackPanel>
                                </Border>

                                <!-- AMP block — cabinet shape -->
                                <Border IsVisible="{Binding IsAmp}"
                                        Width="96" CornerRadius="3,3,10,10"
                                        BorderThickness="2" BorderBrush="#8b1c1c"
                                        Background="#1e0c0c">
                                    <StackPanel Spacing="0">
                                        <Border Height="5" CornerRadius="3,3,0,0"
                                                Background="{Binding FamilyAccentColor}" />
                                        <StackPanel Spacing="3" Margin="8,6,8,8" HorizontalAlignment="Center">
                                            <TextBlock Text="▣" FontSize="14"
                                                       HorizontalAlignment="Center" Foreground="#c0392b" />
                                            <TextBlock Text="AMP" FontSize="11" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#e04040" LetterSpacing="2" />
                                            <TextBlock Text="{Binding Detail}"
                                                       FontSize="9" HorizontalAlignment="Center"
                                                       Foreground="#7a4040" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Regular pedal stompbox card -->
                                <Button IsVisible="{Binding IsRegularPedal}"
                                        Padding="0" Background="Transparent" BorderThickness="0"
                                        Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Pedalboard.SelectPedalboardItemCommand}"
                                        CommandParameter="{Binding Key}">
                                    <Border CornerRadius="6" Padding="0"
                                            MinWidth="110" MaxWidth="130"
                                            Classes="stompbox-card"
                                            Classes.selected="{Binding IsSelected}">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                                <GradientStop Offset="0" Color="#2e3138" />
                                                <GradientStop Offset="1" Color="#1c1f24" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Spacing="0">
                                            <Border Height="6" CornerRadius="6,6,0,0"
                                                    Background="{Binding FamilyAccentColor}" />
                                            <StackPanel Spacing="6" Margin="10,8,10,10">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           HorizontalAlignment="Center"
                                                           FontWeight="Bold" FontSize="12"
                                                           Foreground="#e8e0d0" LetterSpacing="1" />
                                                <Border Width="16" Height="16"
                                                        HorizontalAlignment="Center" CornerRadius="8"
                                                        Background="{Binding LedColor}"
                                                        BorderBrush="#111" BorderThickness="2"
                                                        BoxShadow="0 0 5 2 #60000000" />
                                                <TextBlock Text="{Binding Detail}"
                                                           TextWrapping="Wrap" HorizontalAlignment="Center"
                                                           TextAlignment="Center" MaxWidth="100"
                                                           FontSize="10" Foreground="#9090a0" />
                                                <ToggleButton IsVisible="{Binding CanToggle}"
                                                              HorizontalAlignment="Center"
                                                              Content="ON / OFF"
                                                              IsChecked="{Binding IsActive, Mode=OneWay}"
                                                              Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Pedalboard.TogglePedalboardItemCommand}"
                                                              CommandParameter="{Binding Key}"
                                                              FontSize="10" Padding="8,4" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Button>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Border>
</UserControl>
