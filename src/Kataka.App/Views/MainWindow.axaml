<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Kataka.App.ViewModels"
        xmlns:controls="using:Kataka.App.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1320"
        d:DesignHeight="900"
        x:Class="Kataka.App.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Kataka - Amp Panel">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*" Margin="20" RowSpacing="18">
        <Border Classes="transport-shell" Padding="18">
            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="18" RowSpacing="12">
                <StackPanel Grid.RowSpan="2" Spacing="4">
                    <TextBlock Text="KATAKA"
                               FontSize="28"
                               FontWeight="Bold"
                               LetterSpacing="3" />
                    <TextBlock Text="Linux-first Katana amp editor"
                               Foreground="{StaticResource KatanaSubtleTextBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="MIDI INPUT"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource KatanaSubtleTextBrush}" />
                        <ComboBox Classes="midi-port-picker"
                                  ItemsSource="{Binding InputPorts}"
                                  SelectedItem="{Binding SelectedInputPort}" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="MIDI OUTPUT"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource KatanaSubtleTextBrush}" />
                        <ComboBox Classes="midi-port-picker"
                                  ItemsSource="{Binding OutputPorts}"
                                  SelectedItem="{Binding SelectedOutputPort}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Top">
                    <Button Classes="transport-button"
                            Content="Scan"
                            Command="{Binding ScanCommand}" />
                    <Button Classes="transport-button accent"
                            Content="Connect"
                            Command="{Binding ConnectCommand}" />
                    <Button Classes="transport-button"
                            Content="Disconnect"
                            Command="{Binding DisconnectCommand}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DetectionMessage}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource KatanaSubtleTextBrush}" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="16"
                            VerticalAlignment="Top">
                    <CheckBox Content="Active read sync"
                              IsChecked="{Binding ActiveReadSync}" />
                    <CheckBox Content="Active write sync"
                              IsChecked="{Binding ActiveWriteSync}" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           Text="Read sync controls targeted read-back after writes. Write sync queues knob and toggle edits and flushes them automatically."
                           Foreground="{StaticResource KatanaSubtleTextBrush}"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,360" ColumnSpacing="18">
            <ScrollViewer Grid.Column="0"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <Border Classes="amp-shell" Padding="24">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="18">
                        <!-- ROW 0: AMP CONTROLS | CHANNEL STRIP | DEVICE STATUS -->
                        <Grid ColumnDefinitions="Auto,*,300" ColumnSpacing="14">
                            <!-- AMP CONTROLS -->
                            <Border Classes="panel-section" Padding="16" MinWidth="340">
                                <StackPanel Spacing="10">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="AMP CONTROLS"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   LetterSpacing="1.5" />
                                        <TextBlock Text="{Binding AmpEditorStatus}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource KatanaSubtleTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <WrapPanel Orientation="Horizontal" ItemSpacing="8" LineSpacing="8">
                                        <Button Classes="transport-button" Content="Read" Command="{Binding ReadAmpControlsCommand}" />
                                        <Button Classes="transport-button accent" Content="Push" Command="{Binding WriteAmpControlsCommand}" />
                                    </WrapPanel>
                                    <ItemsControl ItemsSource="{Binding AmpControls}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" ItemSpacing="14" LineSpacing="14" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:AmpControlViewModel">
                                                <controls:RotaryKnob Label="{Binding DisplayName}"
                                                                     Minimum="{Binding Minimum}"
                                                                     Maximum="{Binding Maximum}"
                                                                     Value="{Binding Value}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="AMP TYPE" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                            <ComboBox Classes="midi-port-picker" HorizontalAlignment="Stretch"
                                                      ItemsSource="{x:Static vm:MainWindowViewModel.AmpTypeOptions}"
                                                      SelectedItem="{Binding SelectedAmpType}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="CABINET" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                            <ComboBox Classes="midi-port-picker" HorizontalAlignment="Stretch"
                                                      ItemsSource="{x:Static vm:MainWindowViewModel.CabinetResonanceOptions}"
                                                      SelectedItem="{Binding SelectedCabinetResonance}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- CHANNEL STRIP (inline) -->
                            <Border Grid.Column="1" Classes="panel-section alt" Padding="16">
                                <StackPanel Spacing="10">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="CHANNEL STRIP"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   LetterSpacing="1.5" />
                                        <TextBlock Text="{Binding PanelControlsStatus}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource KatanaSubtleTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <WrapPanel Orientation="Horizontal" ItemSpacing="8" LineSpacing="8">
                                        <Button Classes="transport-button" Content="Read panel" Command="{Binding ReadPanelControlsCommand}" />
                                        <Button Classes="transport-button accent" Content="Push panel" Command="{Binding WritePanelControlsCommand}" />
                                    </WrapPanel>
                                    <ItemsControl ItemsSource="{Binding PanelChannelOptions}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" ItemSpacing="8" LineSpacing="8" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:PanelChannelOptionViewModel">
                                                <ToggleButton Classes="channel-button"
                                                              Content="{Binding DisplayName}"
                                                              IsChecked="{Binding IsSelected}"
                                                              Command="{Binding #RootWindow.DataContext.SelectPanelChannelCommand}"
                                                              CommandParameter="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <WrapPanel Orientation="Horizontal" ItemSpacing="14" LineSpacing="14">
                                        <controls:RotaryKnob Label="Patch Level"
                                                             IsEnabled="{Binding IsPatchLevelAvailable}"
                                                             Minimum="0" Maximum="200"
                                                             Value="{Binding PatchLevel}" />
                                        <Border Classes="panel-section" Padding="12" MinWidth="160">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="TAP TEMPO" FontWeight="Bold" FontSize="12" LetterSpacing="1.2" />
                                                <TextBlock Text="{Binding DelayTapStatus}"
                                                           TextWrapping="Wrap" FontSize="11"
                                                           Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                                <Button Classes="transport-button accent" HorizontalAlignment="Left"
                                                        Content="Tap Delay" Command="{Binding TapDelayCommand}" />
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- DEVICE + LIVE STATUS -->
                            <StackPanel Grid.Column="2" Spacing="14">
                                <Border Classes="panel-section alt" Padding="16">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="DEVICE" FontSize="16" FontWeight="Bold" LetterSpacing="1.5" />
                                        <TextBlock Text="MIDI identity request to confirm the connected amp."
                                                   TextWrapping="Wrap" FontSize="11"
                                                   Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                        <Button Classes="transport-button accent" Content="Request identity"
                                                HorizontalAlignment="Left" Command="{Binding RequestIdentityCommand}" />
                                        <TextBlock Text="IDENTITY REPLY" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                        <TextBlock Text="{Binding IdentityReply}" TextWrapping="Wrap" FontSize="11" />
                                    </StackPanel>
                                </Border>
                                <Border Classes="panel-section" Padding="16">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="LIVE STATUS" FontSize="16" FontWeight="Bold" LetterSpacing="1.5" />
                                        <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding DetectionMessage}" TextWrapping="Wrap" FontSize="11"
                                                   Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- ROW 1: PEDALBOARD CHAIN (minimap) (clickable stompboxes) -->
                        <Border Grid.Row="1" Classes="panel-section alt" Padding="18">
                            <StackPanel Spacing="14">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="PEDALBOARD CHAIN"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               LetterSpacing="1.5" />
                                    <TextBlock Text="A stompbox-style chain overview of the currently surfaced blocks. Pedal FX moves before or after the amp according to its chain-position setting."
                                               Foreground="{StaticResource KatanaSubtleTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding PedalboardItems}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:PedalboardItemViewModel">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                                    <!-- Signal cable -->
                                                    <Canvas IsVisible="{Binding IsConnectedFromPrevious}"
                                                            Width="32" Height="24" VerticalAlignment="Center">
                                                        <Border Canvas.Left="0" Canvas.Top="10" Width="32" Height="4"
                                                                CornerRadius="2" Background="#7a7060" />
                                                        <Border Canvas.Left="0" Canvas.Top="8" Width="7" Height="8"
                                                                CornerRadius="2" Background="#444" />
                                                        <Border Canvas.Left="25" Canvas.Top="8" Width="7" Height="8"
                                                                CornerRadius="2" Background="#444" />
                                                    </Canvas>

                                                    <!-- INPUT / OUTPUT pill node -->
                                                    <Border IsVisible="{Binding IsEndpoint}"
                                                            CornerRadius="20" MinWidth="68" Padding="10,8"
                                                            BorderThickness="2" BorderBrush="#3a5a6a"
                                                            Background="#111c26">
                                                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       FontSize="10" FontWeight="Bold"
                                                                       HorizontalAlignment="Center"
                                                                       Foreground="#7ab0c8" LetterSpacing="1.2" />
                                                            <TextBlock Text="{Binding Detail}"
                                                                       FontSize="9" HorizontalAlignment="Center"
                                                                       Foreground="#3a5a6a" />
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- AMP block — cabinet shape (rounded bottom) -->
                                                    <Border IsVisible="{Binding IsAmp}"
                                                            Width="96" CornerRadius="3,3,10,10"
                                                            BorderThickness="2" BorderBrush="#8b1c1c"
                                                            Background="#1e0c0c">
                                                        <StackPanel Spacing="0">
                                                            <Border Height="5" CornerRadius="3,3,0,0"
                                                                    Background="{Binding FamilyAccentColor}" />
                                                            <StackPanel Spacing="3" Margin="8,6,8,8" HorizontalAlignment="Center">
                                                                <TextBlock Text="▣" FontSize="14"
                                                                           HorizontalAlignment="Center" Foreground="#c0392b" />
                                                                <TextBlock Text="AMP" FontSize="11" FontWeight="Bold"
                                                                           HorizontalAlignment="Center"
                                                                           Foreground="#e04040" LetterSpacing="2" />
                                                                <TextBlock Text="{Binding Detail}"
                                                                           FontSize="9" HorizontalAlignment="Center"
                                                                           Foreground="#7a4040" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Regular pedal stompbox card -->
                                                    <Button IsVisible="{Binding IsRegularPedal}"
                                                            Padding="0" Background="Transparent" BorderThickness="0"
                                                            Command="{Binding #RootWindow.DataContext.SelectPedalboardItemCommand}"
                                                            CommandParameter="{Binding Key}">
                                                        <Border CornerRadius="6" Padding="0"
                                                                MinWidth="110" MaxWidth="130"
                                                                Classes="stompbox-card"
                                                                Classes.selected="{Binding IsSelected}">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                                                    <GradientStop Offset="0" Color="#2e3138" />
                                                                    <GradientStop Offset="1" Color="#1c1f24" />
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                            <StackPanel Spacing="0">
                                                                <Border Height="6" CornerRadius="6,6,0,0"
                                                                        Background="{Binding FamilyAccentColor}" />
                                                                <StackPanel Spacing="6" Margin="10,8,10,10">
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               HorizontalAlignment="Center"
                                                                               FontWeight="Bold" FontSize="12"
                                                                               Foreground="#e8e0d0" LetterSpacing="1" />
                                                                    <Border Width="16" Height="16"
                                                                            HorizontalAlignment="Center" CornerRadius="8"
                                                                            Background="{Binding LedColor}"
                                                                            BorderBrush="#111" BorderThickness="2"
                                                                            BoxShadow="0 0 5 2 #60000000" />
                                                                    <TextBlock Text="{Binding Detail}"
                                                                               TextWrapping="Wrap" HorizontalAlignment="Center"
                                                                               TextAlignment="Center" MaxWidth="100"
                                                                               FontSize="10" Foreground="#9090a0" />
                                                                    <ToggleButton IsVisible="{Binding CanToggle}"
                                                                                  HorizontalAlignment="Center"
                                                                                  Content="ON / OFF"
                                                                                  IsChecked="{Binding IsActive, Mode=OneWay}"
                                                                                  Command="{Binding #RootWindow.DataContext.TogglePedalboardItemCommand}"
                                                                                  CommandParameter="{Binding Key}"
                                                                                  FontSize="10" Padding="8,4" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                    </Button>

                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                        <!-- ROW 2: FULL PEDALBOARD (all controls visible) -->
                        <Border Grid.Row="2" Classes="panel-section alt" Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Text="PEDALBOARD"
                                           FontSize="18" FontWeight="Bold" LetterSpacing="1.5" />

                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding PedalboardItems}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Top" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:PedalboardItemViewModel">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Top">

                                                    <!-- Signal cable between items -->
                                                    <Canvas IsVisible="{Binding IsConnectedFromPrevious}"
                                                            Width="28" Height="40" VerticalAlignment="Top" Margin="0,24,0,0">
                                                        <Border Canvas.Left="0" Canvas.Top="14" Width="28" Height="4"
                                                                CornerRadius="2" Background="#7a7060" />
                                                        <Border Canvas.Left="0" Canvas.Top="12" Width="7" Height="8"
                                                                CornerRadius="2" Background="#444" />
                                                        <Border Canvas.Left="21" Canvas.Top="12" Width="7" Height="8"
                                                                CornerRadius="2" Background="#444" />
                                                    </Canvas>

                                                    <!-- ── INPUT / OUTPUT pill ── -->
                                                    <Border IsVisible="{Binding IsEndpoint}"
                                                            CornerRadius="20" Width="80"
                                                            Padding="10,14"
                                                            BorderThickness="2"
                                                            BorderBrush="#3a5a6a"
                                                            Background="#111c26"
                                                            VerticalAlignment="Top">
                                                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       FontSize="11" FontWeight="Bold"
                                                                       HorizontalAlignment="Center"
                                                                       Foreground="#7ab0c8" LetterSpacing="1.2" />
                                                            <TextBlock Text="{Binding Detail}"
                                                                       FontSize="9" HorizontalAlignment="Center"
                                                                       TextWrapping="Wrap" TextAlignment="Center"
                                                                       Foreground="#3a6070" />
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- ── AMP block ── -->
                                                    <Border IsVisible="{Binding IsAmp}"
                                                            Width="110" CornerRadius="3,3,12,12"
                                                            BorderThickness="2" BorderBrush="#8b1c1c"
                                                            Background="#1e0c0c" VerticalAlignment="Top">
                                                        <StackPanel Spacing="0">
                                                            <Border Height="6" CornerRadius="3,3,0,0"
                                                                    Background="{Binding FamilyAccentColor}" />
                                                            <StackPanel Spacing="5" Margin="10,10,10,12" HorizontalAlignment="Center">
                                                                <TextBlock Text="▣" FontSize="20"
                                                                           HorizontalAlignment="Center"
                                                                           Foreground="#c0392b" />
                                                                <TextBlock Text="AMP" FontSize="13" FontWeight="Bold"
                                                                           HorizontalAlignment="Center"
                                                                           Foreground="#e04040" LetterSpacing="2" />
                                                                <TextBlock Text="{Binding Detail}"
                                                                           FontSize="10" HorizontalAlignment="Center"
                                                                           Foreground="#7a4040" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- ── Panel effect pedal card ── -->
                                                    <Border IsVisible="{Binding IsPanelEffect}"
                                                            Width="190" CornerRadius="8"
                                                            VerticalAlignment="Top">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                                                <GradientStop Offset="0" Color="#2e3138" />
                                                                <GradientStop Offset="1" Color="#1c1f24" />
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <StackPanel Spacing="0">
                                                            <!-- Accent bar: family color (matches minimap) -->
                                                            <Border Height="6" CornerRadius="8,8,0,0"
                                                                    Background="{Binding FamilyAccentColor}" />
                                                            <StackPanel Spacing="10" Margin="12,10,12,14">
                                                                <!-- On/Off toggle -->
                                                                <ToggleButton Classes="effect-button"
                                                                              HorizontalAlignment="Stretch"
                                                                              Content="{Binding PanelEffect.DisplayName}"
                                                                              IsChecked="{Binding PanelEffect.IsEnabled}" />
                                                                <!-- Type selector -->
                                                                <StackPanel Spacing="4" IsVisible="{Binding PanelEffect.HasTypeOptions}">
                                                                    <TextBlock Text="TYPE" FontSize="10" FontWeight="SemiBold"
                                                                               Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                                                    <ComboBox Classes="midi-port-picker"
                                                                              HorizontalAlignment="Stretch"
                                                                              ItemsSource="{Binding PanelEffect.TypeOptions}"
                                                                              SelectedItem="{Binding PanelEffect.SelectedTypeOption}" />
                                                                </StackPanel>
                                                                <!-- Level slider -->
                                                                <StackPanel Spacing="4" IsVisible="{Binding PanelEffect.HasLevel}">
                                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                                        <TextBlock Text="LEVEL" FontSize="10" FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource KatanaSubtleTextBrush}"
                                                                                   VerticalAlignment="Center" />
                                                                        <TextBlock Text="{Binding PanelEffect.Level}" FontSize="10"
                                                                                   Foreground="{StaticResource KatanaSubtleTextBrush}"
                                                                                   VerticalAlignment="Center" />
                                                                    </StackPanel>
                                                                    <Slider Minimum="0" Maximum="100"
                                                                            Value="{Binding PanelEffect.Level}"
                                                                            HorizontalAlignment="Stretch" />
                                                                </StackPanel>
                                                                <!-- Detail parameters -->
                                                                <ItemsControl ItemsSource="{Binding PanelEffect.DetailParams}"
                                                                              IsVisible="{Binding PanelEffect.HasDetailParams}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <StackPanel Spacing="4" Margin="0,4,0,0">
                                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                                    <TextBlock Text="{Binding Label}" FontSize="10"
                                                                                               FontWeight="SemiBold"
                                                                                               Foreground="{StaticResource KatanaSubtleTextBrush}"
                                                                                               VerticalAlignment="Center" />
                                                                                    <TextBlock Text="{Binding Value}" FontSize="10"
                                                                                               Foreground="{StaticResource KatanaSubtleTextBrush}"
                                                                                               VerticalAlignment="Center"
                                                                                               IsVisible="{Binding !IsToggle}" />
                                                                                </StackPanel>
                                                                                <!-- Slider for continuous params -->
                                                                                <Slider Minimum="{Binding Minimum}"
                                                                                        Maximum="{Binding Maximum}"
                                                                                        Value="{Binding Value}"
                                                                                        HorizontalAlignment="Stretch"
                                                                                        IsVisible="{Binding !IsToggle}" />
                                                                                <!-- Toggle for boolean params -->
                                                                                <ToggleButton Classes="effect-button"
                                                                                              HorizontalAlignment="Stretch"
                                                                                              Content="{Binding Label}"
                                                                                              IsChecked="{Binding IsOn}"
                                                                                              IsVisible="{Binding IsToggle}" />
                                                                            </StackPanel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- ── Pedal FX card ── -->
                                                    <Border IsVisible="{Binding IsPedalFx}"
                                                            Width="320" CornerRadius="8"
                                                            VerticalAlignment="Top">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                                                <GradientStop Offset="0" Color="#2e3138" />
                                                                <GradientStop Offset="1" Color="#1c1f24" />
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <StackPanel Spacing="0">
                                                            <Border Height="6" CornerRadius="8,8,0,0" Background="#e85c1a" />
                                                            <StackPanel Spacing="10" Margin="12,10,12,14">
                                                                <!-- On/Off -->
                                                                <ToggleButton Classes="effect-button"
                                                                              HorizontalAlignment="Stretch"
                                                                              Content="PEDAL FX"
                                                                              IsChecked="{Binding #RootWindow.DataContext.PedalFx.IsEnabled}" />
                                                                <!-- Type + Position row -->
                                                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                                    <StackPanel Spacing="4">
                                                                        <TextBlock Text="TYPE" FontSize="10" FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                                                        <ComboBox Classes="midi-port-picker"
                                                                                  HorizontalAlignment="Stretch"
                                                                                  ItemsSource="{Binding #RootWindow.DataContext.PedalFx.TypeOptions}"
                                                                                  SelectedItem="{Binding #RootWindow.DataContext.PedalFx.SelectedTypeOption}" />
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                                        <TextBlock Text="POSITION" FontSize="10" FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                                                        <ComboBox Classes="midi-port-picker"
                                                                                  HorizontalAlignment="Stretch"
                                                                                  ItemsSource="{Binding #RootWindow.DataContext.PedalFx.PositionOptions}"
                                                                                  SelectedItem="{Binding #RootWindow.DataContext.PedalFx.SelectedPositionOption}" />
                                                                    </StackPanel>
                                                                </Grid>
                                                                <!-- Foot volume -->
                                                                <StackPanel Spacing="4">
                                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                                        <TextBlock Text="FOOT VOL" FontSize="10" FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource KatanaSubtleTextBrush}"
                                                                                   VerticalAlignment="Center" />
                                                                        <TextBlock Text="{Binding #RootWindow.DataContext.PedalFx.FootVolume}"
                                                                                   FontSize="10"
                                                                                   Foreground="{StaticResource KatanaSubtleTextBrush}"
                                                                                   VerticalAlignment="Center" />
                                                                    </StackPanel>
                                                                    <Slider Minimum="0" Maximum="100"
                                                                            Value="{Binding #RootWindow.DataContext.PedalFx.FootVolume}"
                                                                            HorizontalAlignment="Stretch" />
                                                                </StackPanel>
                                                                <!-- Wah sub-controls (knobs in 2-column grid) -->
                                                                <StackPanel IsVisible="{Binding #RootWindow.DataContext.PedalFx.IsWahMode}"
                                                                            Spacing="6">
                                                                    <StackPanel Spacing="4">
                                                                        <TextBlock Text="WAH TYPE" FontSize="10" FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                                                        <ComboBox Classes="midi-port-picker"
                                                                                  HorizontalAlignment="Stretch"
                                                                                  ItemsSource="{Binding #RootWindow.DataContext.PedalFx.WahTypeOptions}"
                                                                                  SelectedItem="{Binding #RootWindow.DataContext.PedalFx.SelectedWahTypeOption}" />
                                                                    </StackPanel>
                                                                    <UniformGrid Columns="2" ColumnSpacing="4" RowSpacing="4">
                                                                        <controls:RotaryKnob Label="Position" Minimum="0" Maximum="100"
                                                                                             Value="{Binding #RootWindow.DataContext.PedalFx.PedalPosition}" />
                                                                        <controls:RotaryKnob Label="Min" Minimum="0" Maximum="100"
                                                                                             Value="{Binding #RootWindow.DataContext.PedalFx.PedalMinimum}" />
                                                                        <controls:RotaryKnob Label="Max" Minimum="0" Maximum="100"
                                                                                             Value="{Binding #RootWindow.DataContext.PedalFx.PedalMaximum}" />
                                                                        <controls:RotaryKnob Label="Level" Minimum="0" Maximum="100"
                                                                                             Value="{Binding #RootWindow.DataContext.PedalFx.EffectLevel}" />
                                                                        <controls:RotaryKnob Label="Mix" Minimum="0" Maximum="100"
                                                                                             Value="{Binding #RootWindow.DataContext.PedalFx.DirectMix}" />
                                                                    </UniformGrid>
                                                                </StackPanel>
                                                                <!-- Pedal Bend sub-controls -->
                                                                <StackPanel IsVisible="{Binding #RootWindow.DataContext.PedalFx.IsBendMode}"
                                                                            Spacing="4">
                                                                    <UniformGrid Columns="2" ColumnSpacing="4" RowSpacing="4">
                                                                        <controls:RotaryKnob Label="Pitch" Minimum="-24" Maximum="24"
                                                                                             Value="{Binding #RootWindow.DataContext.PedalFx.BendPitch}" />
                                                                        <controls:RotaryKnob Label="Position" Minimum="0" Maximum="100"
                                                                                             Value="{Binding #RootWindow.DataContext.PedalFx.BendPosition}" />
                                                                        <controls:RotaryKnob Label="Level" Minimum="0" Maximum="100"
                                                                                             Value="{Binding #RootWindow.DataContext.PedalFx.BendEffectLevel}" />
                                                                        <controls:RotaryKnob Label="Mix" Minimum="0" Maximum="100"
                                                                                             Value="{Binding #RootWindow.DataContext.PedalFx.BendDirectMix}" />
                                                                    </UniformGrid>
                                                                </StackPanel>
                                                                <!-- EVH95 sub-controls -->
                                                                <StackPanel IsVisible="{Binding #RootWindow.DataContext.PedalFx.IsEvh95Mode}"
                                                                            Spacing="4">
                                                                    <UniformGrid Columns="2" ColumnSpacing="4" RowSpacing="4">
                                                                        <controls:RotaryKnob Label="Position" Minimum="0" Maximum="100"
                                                                                             Value="{Binding #RootWindow.DataContext.PedalFx.Evh95Position}" />
                                                                        <controls:RotaryKnob Label="Min" Minimum="0" Maximum="100"
                                                                                             Value="{Binding #RootWindow.DataContext.PedalFx.Evh95Minimum}" />
                                                                        <controls:RotaryKnob Label="Max" Minimum="0" Maximum="100"
                                                                                             Value="{Binding #RootWindow.DataContext.PedalFx.Evh95Maximum}" />
                                                                        <controls:RotaryKnob Label="Level" Minimum="0" Maximum="100"
                                                                                             Value="{Binding #RootWindow.DataContext.PedalFx.Evh95EffectLevel}" />
                                                                        <controls:RotaryKnob Label="Mix" Minimum="0" Maximum="100"
                                                                                             Value="{Binding #RootWindow.DataContext.PedalFx.Evh95DirectMix}" />
                                                                    </UniformGrid>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>

                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                    </Grid>
                </Border>
            </ScrollViewer>

            <Border Grid.Column="1" Classes="transport-shell" Padding="18">
                <Grid RowDefinitions="Auto,*" RowSpacing="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="DIAGNOSTICS"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   LetterSpacing="1.5" />
                        <TextBlock Text="The log stays pinned beside the amp controls so you can watch protocol traffic without scrolling away from the panel."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource KatanaSubtleTextBrush}" />
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Classes="diagnostic-log"
                             IsReadOnly="True"
                             Text="{Binding DiagnosticLog}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalAlignment="Stretch" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
