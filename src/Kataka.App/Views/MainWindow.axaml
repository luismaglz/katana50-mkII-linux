<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Kataka.App.ViewModels"
        xmlns:controls="using:Kataka.App.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1320"
        d:DesignHeight="900"
        x:Class="Kataka.App.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Kataka - Amp Panel">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*" Margin="20" RowSpacing="18">
        <Border Classes="transport-shell" Padding="18">
            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="18" RowSpacing="12">
                <StackPanel Grid.RowSpan="2" Spacing="4">
                    <TextBlock Text="KATAKA"
                               FontSize="28"
                               FontWeight="Bold"
                               LetterSpacing="3" />
                    <TextBlock Text="Linux-first Katana amp editor"
                               Foreground="{StaticResource KatanaSubtleTextBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="MIDI INPUT"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource KatanaSubtleTextBrush}" />
                        <ComboBox Classes="midi-port-picker"
                                  ItemsSource="{Binding InputPorts}"
                                  SelectedItem="{Binding SelectedInputPort}" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="MIDI OUTPUT"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource KatanaSubtleTextBrush}" />
                        <ComboBox Classes="midi-port-picker"
                                  ItemsSource="{Binding OutputPorts}"
                                  SelectedItem="{Binding SelectedOutputPort}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Top">
                    <Button Classes="transport-button"
                            Content="Scan"
                            Command="{Binding ScanCommand}" />
                    <Button Classes="transport-button accent"
                            Content="Connect"
                            Command="{Binding ConnectCommand}" />
                    <Button Classes="transport-button"
                            Content="Disconnect"
                            Command="{Binding DisconnectCommand}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DetectionMessage}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource KatanaSubtleTextBrush}" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="16"
                            VerticalAlignment="Top">
                    <CheckBox Content="Active read sync"
                              IsChecked="{Binding ActiveReadSync}" />
                    <CheckBox Content="Active write sync"
                              IsChecked="{Binding ActiveWriteSync}" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           Text="Read sync controls targeted read-back after writes. Write sync queues knob and toggle edits and flushes them automatically."
                           Foreground="{StaticResource KatanaSubtleTextBrush}"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,360" ColumnSpacing="18">
            <ScrollViewer Grid.Column="0"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <Border Classes="amp-shell" Padding="24">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="18">
                        <Grid ColumnDefinitions="*,360" ColumnSpacing="18">
                            <Border Classes="panel-section" Padding="18">
                                <StackPanel Spacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="AMP CONTROLS"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   LetterSpacing="1.5" />
                                        <TextBlock Text="{Binding AmpEditorStatus}"
                                                   Foreground="{StaticResource KatanaSubtleTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <WrapPanel Orientation="Horizontal" ItemSpacing="10" LineSpacing="10">
                                        <Button Classes="transport-button"
                                                Content="Read amp state"
                                                Command="{Binding ReadAmpControlsCommand}" />
                                        <Button Classes="transport-button accent"
                                                Content="Push amp state"
                                                Command="{Binding WriteAmpControlsCommand}" />
                                    </WrapPanel>

                                    <ItemsControl ItemsSource="{Binding AmpControls}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" ItemSpacing="18" LineSpacing="18" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:AmpControlViewModel">
                                                <controls:RotaryKnob Label="{Binding DisplayName}"
                                                                     Minimum="{Binding Minimum}"
                                                                     Maximum="{Binding Maximum}"
                                                                     Value="{Binding Value}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <WrapPanel Orientation="Horizontal" ItemSpacing="18" LineSpacing="18">
                                        <StackPanel Spacing="4" Width="140">
                                            <TextBlock Text="AMP TYPE"
                                                       HorizontalAlignment="Center"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                            <ComboBox Classes="midi-port-picker"
                                                      HorizontalAlignment="Stretch"
                                                      ItemsSource="{x:Static vm:MainWindowViewModel.AmpTypeOptions}"
                                                      SelectedItem="{Binding SelectedAmpType}" />
                                        </StackPanel>
                                        <StackPanel Spacing="4" Width="160">
                                            <TextBlock Text="CABINET RESONANCE"
                                                       HorizontalAlignment="Center"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                            <ComboBox Classes="midi-port-picker"
                                                      HorizontalAlignment="Stretch"
                                                      ItemsSource="{x:Static vm:MainWindowViewModel.CabinetResonanceOptions}"
                                                      SelectedItem="{Binding SelectedCabinetResonance}" />
                                        </StackPanel>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="18">
                                <Border Classes="panel-section alt" Padding="18">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="DEVICE"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   LetterSpacing="1.5" />
                                        <TextBlock Text="Use the standard MIDI identity request to confirm the connected amp is speaking back."
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                        <Button Classes="transport-button accent"
                                                Content="Request identity"
                                                HorizontalAlignment="Left"
                                                Command="{Binding RequestIdentityCommand}" />
                                        <TextBlock Text="IDENTITY REPLY"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                        <TextBlock Text="{Binding IdentityReply}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Classes="panel-section" Padding="18">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="LIVE STATUS"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   LetterSpacing="1.5" />
                                        <TextBlock Text="{Binding StatusMessage}"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding DetectionMessage}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1" Classes="panel-section alt" Padding="18">
                            <StackPanel Spacing="14">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="CHANNEL STRIP"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               LetterSpacing="1.5" />
                                    <TextBlock Text="{Binding PanelControlsStatus}"
                                               Foreground="{StaticResource KatanaSubtleTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <WrapPanel Orientation="Horizontal" ItemSpacing="10" LineSpacing="10">
                                    <Button Classes="transport-button"
                                            Content="Read panel"
                                            Command="{Binding ReadPanelControlsCommand}" />
                                    <Button Classes="transport-button accent"
                                            Content="Push panel"
                                            Command="{Binding WritePanelControlsCommand}" />
                                </WrapPanel>

                                <ItemsControl ItemsSource="{Binding PanelChannelOptions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" ItemSpacing="12" LineSpacing="12" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PanelChannelOptionViewModel">
                                            <ToggleButton Classes="channel-button"
                                                          Content="{Binding DisplayName}"
                                                          IsChecked="{Binding IsSelected}"
                                                          Command="{Binding #RootWindow.DataContext.SelectPanelChannelCommand}"
                                                          CommandParameter="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <WrapPanel Orientation="Horizontal" ItemSpacing="18" LineSpacing="18">
                                    <controls:RotaryKnob Label="Patch Level"
                                                         IsEnabled="{Binding IsPatchLevelAvailable}"
                                                         Minimum="0"
                                                         Maximum="200"
                                                         Value="{Binding PatchLevel}" />

                                    <Border Classes="panel-section" Padding="16" MinWidth="260">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="TAP TEMPO"
                                                       FontWeight="Bold"
                                                       LetterSpacing="1.2" />
                                            <TextBlock Text="{Binding DelayTapStatus}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                            <Button Classes="transport-button accent"
                                                    HorizontalAlignment="Left"
                                                    Content="Tap Delay"
                                                    Command="{Binding TapDelayCommand}" />
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Classes="panel-section alt" Padding="18">
                            <StackPanel Spacing="14">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="PEDAL FX"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               LetterSpacing="1.5" />
                                    <TextBlock Text="{Binding PedalControlsStatus}"
                                               Foreground="{StaticResource KatanaSubtleTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <WrapPanel Orientation="Horizontal" ItemSpacing="10" LineSpacing="10">
                                    <Button Classes="transport-button"
                                            Content="Read pedal"
                                            Command="{Binding ReadPedalControlsCommand}" />
                                    <Button Classes="transport-button accent"
                                            Content="Push pedal"
                                            Command="{Binding WritePedalControlsCommand}" />
                                </WrapPanel>

                                <Border Classes="panel-section" Padding="16">
                                    <StackPanel Spacing="14">
                                        <StackPanel Spacing="12">
                                            <ToggleButton Classes="effect-button"
                                                          HorizontalAlignment="Left"
                                                          Content="PEDAL FX"
                                                          IsChecked="{Binding PedalFx.IsEnabled}" />

                                            <StackPanel Spacing="6">
                                                <TextBlock Text="PEDAL TYPE"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                                <ComboBox Classes="midi-port-picker"
                                                          HorizontalAlignment="Left"
                                                          Width="220"
                                                          ItemsSource="{Binding PedalFx.TypeOptions}"
                                                          SelectedItem="{Binding PedalFx.SelectedTypeOption}" />
                                            </StackPanel>

                                            <StackPanel Spacing="6">
                                                <TextBlock Text="CHAIN POSITION"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                                <ComboBox Classes="midi-port-picker"
                                                          HorizontalAlignment="Left"
                                                          Width="220"
                                                          ItemsSource="{Binding PedalFx.PositionOptions}"
                                                          SelectedItem="{Binding PedalFx.SelectedPositionOption}" />
                                            </StackPanel>

                                            <controls:RotaryKnob Label="Foot Volume"
                                                                 Minimum="0"
                                                                 Maximum="100"
                                                                 Value="{Binding PedalFx.FootVolume}" />
                                        </StackPanel>

                                        <TextBlock Text="Pedal FX chain position is surfaced separately from wah pedal travel. Select a type below to show its subtype controls."
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource KatanaSubtleTextBrush}" />

                                        <StackPanel IsVisible="{Binding PedalFx.IsWahMode}"
                                                    Spacing="12">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="WAH TYPE"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                                <ComboBox Classes="midi-port-picker"
                                                          HorizontalAlignment="Left"
                                                          Width="220"
                                                          ItemsSource="{Binding PedalFx.WahTypeOptions}"
                                                          SelectedItem="{Binding PedalFx.SelectedWahTypeOption}" />
                                            </StackPanel>

                                            <WrapPanel Orientation="Horizontal" ItemSpacing="12" LineSpacing="12">
                                                <controls:RotaryKnob Label="Wah Pos"
                                                                     Minimum="0"
                                                                     Maximum="100"
                                                                     Value="{Binding PedalFx.PedalPosition}" />
                                                <controls:RotaryKnob Label="Wah Min"
                                                                     Minimum="0"
                                                                     Maximum="100"
                                                                     Value="{Binding PedalFx.PedalMinimum}" />
                                                <controls:RotaryKnob Label="Wah Max"
                                                                     Minimum="0"
                                                                     Maximum="100"
                                                                     Value="{Binding PedalFx.PedalMaximum}" />
                                                <controls:RotaryKnob Label="Wah Level"
                                                                     Minimum="0"
                                                                     Maximum="100"
                                                                     Value="{Binding PedalFx.EffectLevel}" />
                                                <controls:RotaryKnob Label="Wah Mix"
                                                                     Minimum="0"
                                                                     Maximum="100"
                                                                     Value="{Binding PedalFx.DirectMix}" />
                                            </WrapPanel>
                                        </StackPanel>

                                        <StackPanel IsVisible="{Binding PedalFx.IsBendMode}"
                                                    Spacing="12">
                                            <WrapPanel Orientation="Horizontal" ItemSpacing="12" LineSpacing="12">
                                                <controls:RotaryKnob Label="Pitch"
                                                                     Minimum="-24"
                                                                     Maximum="24"
                                                                     Value="{Binding PedalFx.BendPitch}" />
                                                <controls:RotaryKnob Label="Pedal Pos"
                                                                     Minimum="0"
                                                                     Maximum="100"
                                                                     Value="{Binding PedalFx.BendPosition}" />
                                                <controls:RotaryKnob Label="Effect Level"
                                                                     Minimum="0"
                                                                     Maximum="100"
                                                                     Value="{Binding PedalFx.BendEffectLevel}" />
                                                <controls:RotaryKnob Label="Direct Mix"
                                                                     Minimum="0"
                                                                     Maximum="100"
                                                                     Value="{Binding PedalFx.BendDirectMix}" />
                                            </WrapPanel>
                                        </StackPanel>

                                        <StackPanel IsVisible="{Binding PedalFx.IsEvh95Mode}"
                                                    Spacing="12">
                                            <WrapPanel Orientation="Horizontal" ItemSpacing="12" LineSpacing="12">
                                                <controls:RotaryKnob Label="Pedal Pos"
                                                                     Minimum="0"
                                                                     Maximum="100"
                                                                     Value="{Binding PedalFx.Evh95Position}" />
                                                <controls:RotaryKnob Label="Pedal Min"
                                                                     Minimum="0"
                                                                     Maximum="100"
                                                                     Value="{Binding PedalFx.Evh95Minimum}" />
                                                <controls:RotaryKnob Label="Pedal Max"
                                                                     Minimum="0"
                                                                     Maximum="100"
                                                                     Value="{Binding PedalFx.Evh95Maximum}" />
                                                <controls:RotaryKnob Label="Effect Level"
                                                                     Minimum="0"
                                                                     Maximum="100"
                                                                     Value="{Binding PedalFx.Evh95EffectLevel}" />
                                                <controls:RotaryKnob Label="Direct Mix"
                                                                     Minimum="0"
                                                                     Maximum="100"
                                                                     Value="{Binding PedalFx.Evh95DirectMix}" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="3" Classes="panel-section alt" Padding="18">
                            <StackPanel Spacing="14">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="PEDALBOARD CHAIN"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               LetterSpacing="1.5" />
                                    <TextBlock Text="A stompbox-style chain overview of the currently surfaced blocks. Pedal FX moves before or after the amp according to its chain-position setting."
                                               Foreground="{StaticResource KatanaSubtleTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding PedalboardItems}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:PedalboardItemViewModel">
                                                <StackPanel Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <!-- Signal cable between pedals -->
                                                    <Canvas IsVisible="{Binding IsConnectedFromPrevious}"
                                                            Width="40" Height="24"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,0,0">
                                                        <!-- cable body -->
                                                        <Border Canvas.Left="0" Canvas.Top="10"
                                                                Width="40" Height="4"
                                                                CornerRadius="2"
                                                                Background="#7a7060" />
                                                        <!-- jack plug left -->
                                                        <Border Canvas.Left="0" Canvas.Top="8"
                                                                Width="7" Height="8"
                                                                CornerRadius="2"
                                                                Background="#444" />
                                                        <!-- jack plug right -->
                                                        <Border Canvas.Left="33" Canvas.Top="8"
                                                                Width="7" Height="8"
                                                                CornerRadius="2"
                                                                Background="#444" />
                                                    </Canvas>

                                                    <!-- Stompbox card -->
                                                    <Border CornerRadius="6"
                                                            Padding="0"
                                                            MinWidth="110"
                                                            MaxWidth="130"
                                                            Margin="0,0,0,0"
                                                            BorderThickness="0">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                                                <GradientStop Offset="0" Color="#2e3138" />
                                                                <GradientStop Offset="1" Color="#1c1f24" />
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <StackPanel Spacing="0">
                                                            <!-- Top accent bar (family color) -->
                                                            <Border Height="6"
                                                                    CornerRadius="6,6,0,0"
                                                                    Background="{Binding FamilyAccentColor}" />

                                                            <!-- Card body -->
                                                            <StackPanel Spacing="7"
                                                                        Margin="10,8,10,10">
                                                                <!-- Name label -->
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           HorizontalAlignment="Center"
                                                                           FontWeight="Bold"
                                                                           FontSize="12"
                                                                           Foreground="#e8e0d0"
                                                                           LetterSpacing="1" />

                                                                <!-- LED indicator -->
                                                                <Border Width="18"
                                                                        Height="18"
                                                                        HorizontalAlignment="Center"
                                                                        CornerRadius="9"
                                                                        Background="{Binding LedColor}"
                                                                        BorderBrush="#111"
                                                                        BorderThickness="2"
                                                                        BoxShadow="0 0 6 2 #60000000" />

                                                                <!-- Detail text (type / variation) -->
                                                                <TextBlock Text="{Binding Detail}"
                                                                           TextWrapping="Wrap"
                                                                           HorizontalAlignment="Center"
                                                                           TextAlignment="Center"
                                                                           MaxWidth="100"
                                                                           FontSize="10"
                                                                           Foreground="#9090a0" />

                                                                <!-- ON/OFF footswitch button -->
                                                                <ToggleButton IsVisible="{Binding CanToggle}"
                                                                              HorizontalAlignment="Center"
                                                                              Content="ON / OFF"
                                                                              IsChecked="{Binding IsActive, Mode=OneWay}"
                                                                              Command="{Binding #RootWindow.DataContext.TogglePedalboardItemCommand}"
                                                                              CommandParameter="{Binding Key}"
                                                                              FontSize="10"
                                                                              Padding="8,4" />

                                                                <!-- AMP / I/O badges -->
                                                                <TextBlock IsVisible="{Binding IsAmp}"
                                                                           Text="PREAMP"
                                                                           HorizontalAlignment="Center"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#9090a0" />
                                                                <TextBlock IsVisible="{Binding IsEndpoint}"
                                                                           Text="I/O"
                                                                           HorizontalAlignment="Center"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#9090a0" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="4" Classes="panel-section" Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="EFFECTS AND VARIATIONS"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           LetterSpacing="1.5" />
                                <ItemsControl ItemsSource="{Binding PanelEffects}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" ItemWidth="170" ItemHeight="165" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PanelEffectViewModel">
                                            <Border Classes="panel-section alt" Padding="14" Margin="0,0,12,12">
                                                <StackPanel Spacing="10">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               HorizontalAlignment="Center"
                                                               FontWeight="Bold" />
                                                    <ToggleButton Classes="effect-button"
                                                                  HorizontalAlignment="Center"
                                                                  Content="ENGAGE"
                                                                  IsChecked="{Binding IsEnabled}" />
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Center"
                                                                Spacing="8">
                                                        <Border Width="16"
                                                                Height="16"
                                                                CornerRadius="8"
                                                                Background="{Binding VariationBrush}"
                                                                BorderBrush="#f4f1e8"
                                                                BorderThickness="1" />
                                                        <TextBlock Text="{Binding VariationCaption}"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                                    </StackPanel>
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="TYPE"
                                                                   HorizontalAlignment="Center"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                                        <ComboBox Classes="midi-port-picker"
                                                                  HorizontalAlignment="Stretch"
                                                                  ItemsSource="{Binding TypeOptions}"
                                                                  SelectedItem="{Binding SelectedTypeOption}" />
                                                    </StackPanel>
                                                    <StackPanel Spacing="4" IsVisible="{Binding HasLevel}">
                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Center"
                                                                    Spacing="4">
                                                            <TextBlock Text="LEVEL"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                                            <TextBlock Text="{Binding Level}"
                                                                       FontSize="11"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{StaticResource KatanaSubtleTextBrush}" />
                                                        </StackPanel>
                                                        <Slider Minimum="0"
                                                                Maximum="100"
                                                                Value="{Binding Level}"
                                                                HorizontalAlignment="Stretch" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </ScrollViewer>

            <Border Grid.Column="1" Classes="transport-shell" Padding="18">
                <Grid RowDefinitions="Auto,*" RowSpacing="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="DIAGNOSTICS"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   LetterSpacing="1.5" />
                        <TextBlock Text="The log stays pinned beside the amp controls so you can watch protocol traffic without scrolling away from the panel."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource KatanaSubtleTextBrush}" />
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Classes="diagnostic-log"
                             IsReadOnly="True"
                             Text="{Binding DiagnosticLog}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalAlignment="Stretch" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
