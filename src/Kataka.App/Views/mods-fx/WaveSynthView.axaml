<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{x:Static dvm:DesignModFxPedalViewModel.Instance}"
             x:Class="Kataka.App.Views.ModsFx.WaveSynthView"
             x:DataType="vm:ModFxPedalViewModel">
    <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnob Scale="0.55" Label="WAVE"
                                 Minimum="0" Maximum="1"
                                 Value="{Binding WaveSynthWave}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="CUTOFF"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding WaveSynthCutoff}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="RESONANCE"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding WaveSynthResonance}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="FILTER SENS"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding WaveSynthFilterSens}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="FILTER DECAY"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding WaveSynthFilterDecay}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="FILTER DEPTH"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding WaveSynthFilterDepth}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="SYNTH LEVEL"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding WaveSynthSynthLevel}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="DIRECT MIX"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding WaveSynthDirectMix}"
                                 LabelFontSize="11" />
        </StackPanel>
    </StackPanel>
</UserControl>
