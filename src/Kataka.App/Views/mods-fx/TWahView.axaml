<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Kataka.App.Views.ModsFx.TWahView"
             x:DataType="vm:ModFxPedalViewModel">
    <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnob Scale="0.55" Label="MODE"
                                 Minimum="0" Maximum="1"
                                 Value="{Binding TWahMode}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="POLARITY"
                                 Minimum="0" Maximum="1"
                                 Value="{Binding TWahPolarity}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="SENS"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding TWahSens}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="FREQ"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding TWahFreq}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="PEAK"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding TWahPeak}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="DIRECT MIX"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding TWahDirectMix}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="E.LEVEL"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding TWahEffectLevel}"
                                 LabelFontSize="11" />
        </StackPanel>
    </StackPanel>
</UserControl>
