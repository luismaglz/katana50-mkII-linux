<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{x:Static dvm:DesignModFxPedalViewModel.Instance}"
             x:Class="Kataka.App.Views.ModsFx.SlicerView"
             x:DataType="vm:ModFxPedalViewModel">
    <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnob Scale="0.55" Label="PATTERN"
                                 Minimum="0" Maximum="19"
                                 Value="{Binding SlicerPattern}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="RATE"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding SlicerRate}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="TRIG SENS"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding SlicerTriggerSens}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="E.LEVEL"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding SlicerEffectLevel}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="DIRECT MIX"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding SlicerDirectMix}"
                                 LabelFontSize="11" />
        </StackPanel>
    </StackPanel>
</UserControl>
