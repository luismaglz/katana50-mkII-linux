<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{x:Static dvm:DesignModFxPedalViewModel.Instance}"
             x:Class="Kataka.App.Views.ModsFx.LimiterView"
             x:DataType="vm:ModFxPedalViewModel">
    <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnob Scale="0.55" Label="TYPE"
                                 Minimum="0" Maximum="2"
                                 Value="{Binding LimiterType}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="ATTACK"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding LimiterAttack}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="THRESHOLD"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding LimiterThreshold}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="RATIO"
                                 Minimum="0" Maximum="17"
                                 Value="{Binding LimiterRatio}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="RELEASE"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding LimiterRelease}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="LEVEL"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding LimiterLevel}"
                                 LabelFontSize="11" />
        </StackPanel>
    </StackPanel>
</UserControl>
