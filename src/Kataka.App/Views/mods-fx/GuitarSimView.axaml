<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Kataka.App.Views.ModsFx.GuitarSimView"
             x:DataType="vm:ModFxPedalViewModel">
    <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnob Scale="0.55" Label="TYPE"
                                 Minimum="0" Maximum="7"
                                 Value="{Binding GuitarSimType}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="LOW"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding GuitarSimLow}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="HIGH"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding GuitarSimHigh}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="LEVEL"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding GuitarSimLevel}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="BODY"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding GuitarSimBody}"
                                 LabelFontSize="11" />
        </StackPanel>
    </StackPanel>
</UserControl>
