<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Kataka.App.Views.ModsFx.TremoloView"
             x:DataType="vm:ModFxPedalViewModel">
    <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnob Scale="0.55" Label="WAVE SHAPE"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding TremoloWaveShape}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="RATE"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding TremoloRate}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="DEPTH"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding TremoloDepth}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="LEVEL"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding TremoloLevel}"
                                 LabelFontSize="11" />
        </StackPanel>
    </StackPanel>
</UserControl>
