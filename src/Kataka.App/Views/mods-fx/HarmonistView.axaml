<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{x:Static dvm:DesignModFxPedalViewModel.Instance}"
             x:Class="Kataka.App.Views.ModsFx.HarmonistView"
             x:DataType="vm:ModFxPedalViewModel">
    <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnob Scale="0.55" Label="VOICE"
                                 Minimum="0" Maximum="1"
                                 Value="{Binding HarmonistVoice}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="HARMONY 1"
                                 Minimum="0" Maximum="29"
                                 Value="{Binding HarmonistHarmony1}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="LEVEL 1"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding HarmonistLevel1}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="HARMONY 2"
                                 Minimum="0" Maximum="29"
                                 Value="{Binding HarmonistHarmony2}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="LEVEL 2"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding HarmonistLevel2}"
                                 LabelFontSize="11" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnob Scale="0.55" Label="FEEDBACK"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding HarmonistFeedback}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="DIRECT MIX"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding HarmonistDirectMix}"
                                 LabelFontSize="11" />
        </StackPanel>
    </StackPanel>
</UserControl>
