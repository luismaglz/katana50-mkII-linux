<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Kataka.App.Views.ModsFx.PedalBendView"
             x:DataType="vm:ModFxPedalViewModel">
    <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnob Scale="0.55" Label="PITCH"
                                 Minimum="0" Maximum="48"
                                 Value="{Binding PedalBendPitch}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="PEDAL POS"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding PedalBendPedalPosition}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="E.LEVEL"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding PedalBendEffectLevel}"
                                 LabelFontSize="11" />
            <controls:RotaryKnob Scale="0.55" Label="DIRECT MIX"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding PedalBendDirectMix}"
                                 LabelFontSize="11" />
        </StackPanel>
    </StackPanel>
</UserControl>
