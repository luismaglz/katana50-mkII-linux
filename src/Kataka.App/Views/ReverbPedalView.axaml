<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="200"
             d:DesignHeight="320"
             d:DataContext="{x:Static dvm:DesignReverbPedalViewModel.Instance}"
             x:Class="Kataka.App.Views.ReverbPedalView"
             x:DataType="vm:ReverbPedalViewModel">

    <Border MinWidth="160" CornerRadius="8" VerticalAlignment="Top">
        <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Offset="0" Color="#2e3138" />
                <GradientStop Offset="1" Color="#1c1f24" />
            </LinearGradientBrush>
        </Border.Background>
        <StackPanel Spacing="0">
            <!-- Reverb accent bar: purple -->
            <Border Height="6" CornerRadius="8,8,0,0" Background="#9b40e0" />
            <StackPanel Spacing="10" Margin="12,10,12,14">
                <!-- On/Off toggle + LED -->
                <controls:PedalHeaderControl />
                <!-- Type selector -->
                <StackPanel Spacing="4" IsVisible="{Binding HasTypeOptions}">
                    <TextBlock Text="TYPE" FontSize="10" FontWeight="SemiBold"
                               Foreground="#5a2088" />
                    <ComboBox Classes="midi-port-picker"
                              HorizontalAlignment="Stretch"
                              ItemsSource="{Binding TypeOptions}"
                              SelectedItem="{Binding SelectedTypeOption}" />
                </StackPanel>
                <!-- Variation color -->
                <StackPanel Spacing="4">
                    <TextBlock Text="VARIATION" FontSize="10" FontWeight="SemiBold"
                               Foreground="#5a2088" />
                    <Border Height="16" CornerRadius="4"
                            Background="{Binding VariationBrush}" />
                </StackPanel>
                <!-- Level knob -->
                <controls:RotaryKnob Scale="0.6" Label="LEVEL"
                                     Minimum="0" Maximum="100"
                                     Value="{Binding Level}"
                                     IsVisible="{Binding HasLevel}"
                                     HorizontalAlignment="Center" />
                <!-- Reverb controls -->
                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <controls:RotaryKnob Scale="0.6" Label="TIME"
                                         Minimum="0" Maximum="127"
                                         Value="{Binding Time}" />
                    <controls:RotaryKnob Scale="0.6" Label="PRE DELAY"
                                         Minimum="0" Maximum="127"
                                         Value="{Binding PreDelay}" />
                    <controls:RotaryKnob Scale="0.6" Label="HI CUT"
                                         Minimum="0" Maximum="17"
                                         Value="{Binding HighCut}" />
                    <Border Width="70" Height="94" Padding="8">
                        <ToggleButton Classes="effect-button"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      Content="HI DENSITY"
                                      IsChecked="{Binding HighDensity}" />
                    </Border>
                    <controls:RotaryKnob Scale="0.6" Label="E.LEVEL"
                                         Minimum="0" Maximum="127"
                                         Value="{Binding EffectLevel}" />
                    <controls:RotaryKnob Scale="0.6" Label="D.MIX"
                                         Minimum="0" Maximum="127"
                                         Value="{Binding DirectMix}" />
                </WrapPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
