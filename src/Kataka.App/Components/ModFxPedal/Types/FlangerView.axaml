<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{x:Static dvm:DesignModFxPedalViewModel.Instance}"
             x:Class="Kataka.App.Views.ModsFx.FlangerView"
             x:DataType="vm:ModFxPedalViewModel"
             x:CompileBindings="False">

    <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnobV2 Scale="0.75" Label="RATE"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding FlangerRate}"
                                   LabelFontSize="16" ValueFontSize="14" />
            <controls:RotaryKnobV2 Scale="0.75" Label="DEPTH"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding FlangerDepth}"
                                   LabelFontSize="16" ValueFontSize="14" />
            <controls:RotaryKnobV2 Scale="0.75" Label="MANUAL"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding FlangerManual}"
                                   LabelFontSize="16" ValueFontSize="14" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnobV2 Scale="0.75" Label="RESONANCE"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding FlangerResonance}"
                                   LabelFontSize="16" ValueFontSize="14" />

            <controls:SteppedKnobV2 Label="LOW CUT" Scale="0.75"
                                    Steps="{x:Static vm:FrequencySteps.LowCut11}"
                                    Value="{Binding FlangerLowCut}"
                                    LabelFontSize="16" />
            <controls:RotaryKnobV2 Scale="0.75" Label="E.LEVEL"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding FlangerEffectLevel}"
                                   LabelFontSize="16" ValueFontSize="14" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnobV2 Scale="0.75" Label="DIRECT MIX"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding FlangerDirectMix}"
                                   LabelFontSize="16" ValueFontSize="14" />
        </StackPanel>
    </StackPanel>

</UserControl>
