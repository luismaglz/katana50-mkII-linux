<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{x:Static dvm:DesignModFxPedalViewModel.Instance}"
             x:Class="Kataka.App.Views.ModsFx.LimiterView"
             x:DataType="vm:ModFxPedalViewModel"
             x:CompileBindings="False">
    <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <ComboBox ItemsSource="{Binding LimiterTypeOptions}"
                      SelectedItem="{Binding LimiterTypeOption}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnobV2 Scale="0.75" Label="ATTACK"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding LimiterAttack}"
                                   LabelFontSize="11" />
            <controls:RotaryKnobV2 Scale="0.75" Label="THRESHOLD"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding LimiterThreshold}"
                                   LabelFontSize="11" />
            <controls:RotaryKnobV2 Scale="0.75" Label="RATIO"
                                   Minimum="0" Maximum="17"
                                   Value="{Binding LimiterRatio}"
                                   LabelFontSize="11" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnobV2 Scale="0.75" Label="RELEASE"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding LimiterRelease}"
                                   LabelFontSize="11" />
            <controls:RotaryKnobV2 Scale="0.75" Label="LEVEL"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding LimiterLevel}"
                                   LabelFontSize="11" />
        </StackPanel>
    </StackPanel>
</UserControl>
