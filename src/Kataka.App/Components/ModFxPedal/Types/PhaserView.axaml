<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{x:Static dvm:DesignModFxPedalViewModel.Instance}"
             x:Class="Kataka.App.Views.ModsFx.PhaserView"
             x:DataType="vm:ModFxPedalViewModel"
             x:CompileBindings="False">
    <UserControl.Styles>
        <Style Selector="controls|RotaryKnobV2">
            <Setter Property="LabelBrush" Value="{Binding KnobLabelBrush}" />
            <Setter Property="ValueBrush" Value="{Binding KnobValueBrush}" />
            <Setter Property="AccentColor" Value="{Binding KnobAccentColor}" />
        </Style>
    </UserControl.Styles>


    <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnobV2 Scale="0.75" Label="RATE"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding PhaserRate}"
                                   LabelFontSize="16" ValueFontSize="14" />
            <controls:RotaryKnobV2 Scale="0.75" Label="DEPTH"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding PhaserDepth}"
                                   LabelFontSize="16" ValueFontSize="14" />
            <controls:RotaryKnobV2 Scale="0.75" Label="MANUAL"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding PhaserManual}"
                                   LabelFontSize="16" ValueFontSize="14" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnobV2 Scale="0.75" Label="RESONANCE"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding PhaserResonance}"
                                   LabelFontSize="16" ValueFontSize="14" />

            <controls:RotaryKnobV2 Scale="0.75" Label="STEP RATE"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding PhaserStepRate}"
                                   LabelFontSize="16" ValueFontSize="14" />
            <controls:RotaryKnobV2 Scale="0.75" Label="E.LEVEL"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding PhaserEffectLevel}"
                                   LabelFontSize="16" ValueFontSize="14" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnobV2 Scale="0.75" Label="DIRECT MIX"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding PhaserDirectMix}"
                                   LabelFontSize="16" ValueFontSize="14" />
            <ComboBox ItemsSource="{Binding PhaserTypeOptions}"
                      SelectedItem="{Binding PhaserTypeOption}" />
        </StackPanel>
    </StackPanel>

</UserControl>
