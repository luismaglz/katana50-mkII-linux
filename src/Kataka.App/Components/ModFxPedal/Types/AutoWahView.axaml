<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{x:Static dvm:DesignModFxPedalViewModel.Instance}"
             x:Class="Kataka.App.Views.ModsFx.AutoWahView"
             x:DataType="vm:ModFxPedalViewModel"
             x:CompileBindings="False">
    <UserControl.Styles>
        <Style Selector="controls|RotaryKnobV2">
            <Setter Property="LabelBrush" Value="{Binding KnobLabelBrush}" />
            <Setter Property="ValueBrush" Value="{Binding KnobValueBrush}" />
            <Setter Property="AccentColor" Value="{Binding KnobAccentColor}" />
        </Style>
    </UserControl.Styles>

    <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnobV2 Scale="0.75" Label="MODE"
                                   Minimum="0" Maximum="1"
                                   Value="{Binding AutoWahMode}"
                                   LabelFontSize="16" ValueFontSize="14" />
            <controls:RotaryKnobV2 Scale="0.75" Label="FREQ"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding AutoWahFreq}"
                                   LabelFontSize="16" ValueFontSize="14" />
            <controls:RotaryKnobV2 Scale="0.75" Label="PEAK"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding AutoWahPeak}"
                                   LabelFontSize="16" ValueFontSize="14" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

            <controls:RotaryKnobV2 Scale="0.75" Label="RATE"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding AutoWahRate}"
                                   LabelFontSize="16" ValueFontSize="14" />
            <controls:RotaryKnobV2 Scale="0.75" Label="DEPTH"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding AutoWahDepth}"
                                   LabelFontSize="16" ValueFontSize="14" />
            <controls:RotaryKnobV2 Scale="0.75" Label="DIRECT MIX"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding AutoWahDirectMix}"
                                   LabelFontSize="16" ValueFontSize="14" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnobV2 Scale="0.75" Label="E.LEVEL"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding AutoWahEffectLevel}"
                                   LabelFontSize="16" ValueFontSize="14" />
        </StackPanel>
    </StackPanel>
</UserControl>
