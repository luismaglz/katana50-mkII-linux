<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{x:Static dvm:DesignModFxPedalViewModel.Instance}"
             x:Class="Kataka.App.Views.ModsFx.RingModView"
             x:DataType="vm:ModFxPedalViewModel"
             x:CompileBindings="False">
    <StackPanel Spacing="8">
        <ComboBox ItemsSource="{Binding RingModModeOptions}"
                  SelectedItem="{Binding RingModModeOption}" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

            <controls:RotaryKnobV2 Scale="0.75" Label="FREQUENCY"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding RingModFrequency}"
                                   LabelFontSize="16" ValueFontSize="14" />
            <controls:RotaryKnobV2 Scale="0.75" Label="E.LEVEL"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding RingModEffectLevel}"
                                   LabelFontSize="16" ValueFontSize="14" />
            <controls:RotaryKnobV2 Scale="0.75" Label="DIRECT MIX"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding RingModDirectMix}"
                                   LabelFontSize="16" ValueFontSize="14" />
        </StackPanel>
    </StackPanel>
</UserControl>
