<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{x:Static dvm:DesignModFxPedalViewModel.Instance}"
             x:Class="Kataka.App.Views.ModsFx.ParametricEqView"
             x:DataType="vm:ModFxPedalViewModel"
             x:CompileBindings="False">
    <StackPanel Spacing="8">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:SteppedKnobV2 Scale="0.75" Label="LOW CUT"
                                    Steps="{x:Static vm:FrequencySteps.LowCut18}"
                                    Value="{Binding ParametricEqLowCut}"
                                    LabelFontSize="10" />
            <controls:RotaryKnobV2 Scale="0.75" Label="LOW GAIN"
                                   Minimum="0" Maximum="40"
                                   Value="{Binding ParametricEqLowGain}"
                                   LabelFontSize="10" />
            <controls:RotaryKnobV2 Scale="0.75" Label="LOW-MID FREQ"
                                   Minimum="0" Maximum="27"
                                   Value="{Binding ParametricEqLowMidFreq}"
                                   LabelFontSize="10" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

            <controls:RotaryKnobV2 Scale="0.75" Label="LOW-MID Q"
                                   Minimum="0" Maximum="5"
                                   Value="{Binding ParametricEqLowMidQ}"
                                   LabelFontSize="10" />
            <controls:RotaryKnobV2 Scale="0.75" Label="LOW-MID GAIN"
                                   Minimum="0" Maximum="40"
                                   Value="{Binding ParametricEqLowMidGain}"
                                   LabelFontSize="10" />
            <controls:RotaryKnobV2 Scale="0.75" Label="HIGH-MID FREQ"
                                   Minimum="0" Maximum="27"
                                   Value="{Binding ParametricEqHighMidFreq}"
                                   LabelFontSize="10" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:RotaryKnobV2 Scale="0.75" Label="HIGH-MID Q"
                                   Minimum="0" Maximum="5"
                                   Value="{Binding ParametricEqHighMidQ}"
                                   LabelFontSize="10" />
            <controls:RotaryKnobV2 Scale="0.75" Label="HIGH-MID GAIN"
                                   Minimum="0" Maximum="40"
                                   Value="{Binding ParametricEqHighMidGain}"
                                   LabelFontSize="10" />
            <controls:RotaryKnobV2 Scale="0.75" Label="HIGH GAIN"
                                   Minimum="0" Maximum="40"
                                   Value="{Binding ParametricEqHighGain}"
                                   LabelFontSize="10" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

            <controls:SteppedKnobV2 Scale="0.75" Label="HIGH CUT"
                                    Steps="{x:Static vm:FrequencySteps.HighCut15}"
                                    Value="{Binding ParametricEqHighCut}"
                                    LabelFontSize="10" />
            <controls:RotaryKnobV2 Scale="0.75" Label="LEVEL"
                                   Minimum="0" Maximum="40"
                                   Value="{Binding ParametricEqLevel}"
                                   LabelFontSize="10" />
        </StackPanel>
    </StackPanel>
</UserControl>
