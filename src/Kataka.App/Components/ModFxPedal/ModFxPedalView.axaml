<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:modsfx="using:Kataka.App.Views.ModsFx"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="280"
             d:DesignHeight="420"
             d:DataContext="{x:Static dvm:DesignModFxPedalViewModel.Instance}"
             x:Class="Kataka.App.Views.ModFxPedalView"
             x:DataType="vm:ModFxPedalViewModel"
             x:CompileBindings="False">

    <controls:PedalCardBorder MinWidth="200" CornerRadius="8" VerticalAlignment="Top"
                              Background="{Binding CardBackgroundBrush}">
        <Grid>
            <StackPanel Spacing="0">
                <!-- Accent bar: green for mod, blue for fx — driven by FamilyAccentColor in parent but we use green default -->
                <StackPanel Spacing="10" Margin="12,10,12,14">

                    <!-- On/Off toggle + LED -->
                    <controls:PedalHeaderControl />

                    <!-- Type selector -->
                    <StackPanel Spacing="4" IsVisible="{Binding HasTypeOptions}">
                        <TextBlock Text="TYPE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{Binding TypeLabelBrush}" />
                        <ComboBox Classes="midi-port-picker"
                                  HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding TypeOptions}"
                                  SelectedItem="{Binding SelectedTypeOption}" />
                    </StackPanel>


                    <!-- Type-specific body — one panel visible at a time -->
                    <modsfx:ChorusView IsVisible="{Binding IsTypeChorus}" />
                    <modsfx:FlangerView IsVisible="{Binding IsTypeFlanger}" />
                    <modsfx:PhaserView IsVisible="{Binding IsTypePhaser}" />
                    <modsfx:UniVView IsVisible="{Binding IsTypeUnivibe}" />
                    <modsfx:TremoloView IsVisible="{Binding IsTypeTremolo}" />
                    <modsfx:VibratoView IsVisible="{Binding IsTypeVibrato}" />
                    <modsfx:RotaryView IsVisible="{Binding IsTypeRotary}" />
                    <modsfx:RingModView IsVisible="{Binding IsTypeRingMod}" />
                    <modsfx:SlowGearView IsVisible="{Binding IsTypeSlowGear}" />
                    <modsfx:SlicerView IsVisible="{Binding IsTypeSlicer}" />
                    <modsfx:CompView IsVisible="{Binding IsTypeComp}" />
                    <modsfx:LimiterView IsVisible="{Binding IsTypeLimiter}" />
                    <modsfx:TWahView IsVisible="{Binding IsTypeTouchWah}" />
                    <modsfx:AutoWahView IsVisible="{Binding IsTypeAutoWah}" />
                    <modsfx:PedalWahView IsVisible="{Binding IsTypePedalWah}" />
                    <modsfx:GraphicEqView IsVisible="{Binding IsTypeGraphicEq}" />
                    <modsfx:ParametricEqView IsVisible="{Binding IsTypeParametricEq}" />
                    <modsfx:GuitarSimView IsVisible="{Binding IsTypeGuitarSim}" />
                    <modsfx:AcGuitarSimView IsVisible="{Binding IsTypeAcGuitarSim}" />
                    <modsfx:AcProcessorView IsVisible="{Binding IsTypeAcProcessor}" />
                    <modsfx:WaveSynthView IsVisible="{Binding IsTypeWaveSynth}" />
                    <modsfx:OctaveView IsVisible="{Binding IsTypeOctave}" />
                    <modsfx:HeavyOctaveView IsVisible="{Binding IsTypeHeavyOctave}" />
                    <modsfx:PitchShifterView IsVisible="{Binding IsTypePitchShifter}" />
                    <modsfx:HarmonistView IsVisible="{Binding IsTypeHarmonist}" />
                    <modsfx:HumanizerView IsVisible="{Binding IsTypeHumanizer}" />
                    <modsfx:Phaser90EView IsVisible="{Binding IsTypePhaser90E}" />
                    <modsfx:Flanger117EView IsVisible="{Binding IsTypeFlanger117E}" />
                    <modsfx:Wah95EView IsVisible="{Binding IsTypeWah95E}" />
                    <modsfx:DC30View IsVisible="{Binding IsTypeDc30}" />
                    <modsfx:PedalBendView IsVisible="{Binding IsTypePedalBend}" />

                </StackPanel>
            </StackPanel>
            <Border IsHitTestVisible="False" CornerRadius="8">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#33FFFFFF" Offset="0" />
                        <GradientStop Color="#00000000" Offset="0.5" />
                        <GradientStop Color="#40000000" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Grid>
    </controls:PedalCardBorder>

</UserControl>
