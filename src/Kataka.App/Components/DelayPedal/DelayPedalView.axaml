<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ptb="clr-namespace:Kataka.App.Components.PhysicalToggleButton"
             mc:Ignorable="d"
             d:DesignWidth="300"
             d:DesignHeight="520"
             d:DataContext="{x:Static dvm:DesignDelayPedalViewModel.Instance}"
             x:Class="Kataka.App.Views.DelayPedalView"
             x:DataType="vm:DelayPedalViewModel"
             x:CompileBindings="False">

    <UserControl.Styles>
        <Style Selector="controls|RotaryKnobV2, controls|SteppedKnobV2">
            <Setter Property="LabelBrush" Value="{Binding KnobLabelBrush}" />
            <Setter Property="ValueBrush" Value="{Binding KnobValueBrush}" />
            <Setter Property="AccentColor" Value="{Binding KnobAccentColor}" />
        </Style>
    </UserControl.Styles>

    <controls:PedalCardBorder MinWidth="160" CornerRadius="8" VerticalAlignment="Top"
                              Background="{Binding CardBackgroundBrush}">
        <Grid>
            <StackPanel Spacing="0">
                <StackPanel Spacing="10" Margin="12,10,12,14">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <controls:PedalHeaderControl />
                        <ComboBox Classes="midi-port-picker" VerticalAlignment="Center"
                                  ItemsSource="{Binding TypeOptions}"
                                  SelectedItem="{Binding SelectedTypeOption}" />
                    </StackPanel>

                    <!-- Row 1: Feedback, HiCut, E.Level, D.Mix -->
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <controls:RotaryKnobV2 Label="FEEDBACK" Scale="0.75"
                                               Description="Adjusts the volume returned to the input. Higher values increase the number of delay repeats."
                                               Minimum="0" Maximum="100"
                                               Value="{Binding Feedback}"
                                               LabelFontSize="16" ValueFontSize="14" />
                        <controls:SteppedKnobV2 Label="HI CUT" Scale="0.75"
                                                Description="Sets the frequency at which the high cut filter takes effect. At maximum (FLAT), the filter has no effect."
                                                Steps="{x:Static vm:FrequencySteps.HighCut15}"
                                                Value="{Binding HighCut}"
                                                LabelFontSize="16" />
                        <controls:RotaryKnobV2 Label="E.LEVEL" Scale="0.75"
                                               Description="Adjusts the volume of the delay (effect) sound."
                                               Minimum="0" Maximum="120"
                                               Value="{Binding EffectLevel}"
                                               LabelFontSize="16" ValueFontSize="14" />
                    </StackPanel>


                    <!-- Row 2: TapTime (PAN only), ModRate/ModDepth (MODULATE/SDE-3000 only) -->
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <controls:RotaryKnobV2 Label="D.MIX" Scale="0.75"
                                               Description="Adjusts the volume of the direct (dry) sound."
                                               Minimum="0" Maximum="100"
                                               Value="{Binding DirectMix}"
                                               LabelFontSize="16" ValueFontSize="14" />
                        <controls:RotaryKnobV2 Label="TAP TIME" Scale="0.75"
                                               IsVisible="{Binding IsTypePan}"
                                               Description="Adjusts the delay time of the right channel relative to the left channel (100%). Only active when TYPE is PAN."
                                               Minimum="0" Maximum="100"
                                               Value="{Binding TapTime}"
                                               LabelFontSize="16" ValueFontSize="14" />
                        <controls:RotaryKnobV2 Label="MOD RATE" Scale="0.75"
                                               IsVisible="{Binding IsTypeModulateOrSde}"
                                               Description="Adjusts the modulation rate of the delay sound. Only active when TYPE is MODULATE or SDE-3000."
                                               Minimum="0" Maximum="100"
                                               Value="{Binding ModRate}"
                                               LabelFontSize="16" ValueFontSize="14" />
                        <controls:RotaryKnobV2 Label="MOD DEPTH" Scale="0.75"
                                               IsVisible="{Binding IsTypeModulateOrSde}"
                                               Description="Adjusts the modulation depth of the delay sound. Only active when TYPE is MODULATE or SDE-3000."
                                               Minimum="0" Maximum="100"
                                               Value="{Binding ModDepth}"
                                               LabelFontSize="16" ValueFontSize="14" />

                    </StackPanel>

                    <!-- Toggles row 1: Range, Filter, ModSw (SDE-3000 only) -->
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="8">

                        <ptb:PhysicalToggleButtonView
                            DisplayName="17kHz"
                            IsVisible="{Binding IsTypeSde3000}"
                            IsChecked="{Binding RangeHigh}" />
                        <ptb:PhysicalToggleButtonView
                            DisplayName="FILTER"
                            IsVisible="{Binding IsTypeSde3000}"
                            IsChecked="{Binding FilterOn}" />
                        <ptb:PhysicalToggleButtonView
                            DisplayName="MOD SW"
                            IsVisible="{Binding IsTypeSde3000}"
                            IsChecked="{Binding ModSwOn}" />

                    </StackPanel>

                    <!-- Toggles row 2: FeedbackPhase, DelayPhase (SDE-3000 only) -->
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="8">

                        <ptb:PhysicalToggleButtonView
                            DisplayName="FB INV"
                            IsVisible="{Binding IsTypeSde3000}"
                            IsChecked="{Binding FeedbackPhaseInverse}" />
                        <ptb:PhysicalToggleButtonView
                            DisplayName="DLY INV"
                            IsVisible="{Binding IsTypeSde3000}"
                            IsChecked="{Binding DelayPhaseInverse}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <Border IsHitTestVisible="False" CornerRadius="8">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#33FFFFFF" Offset="0" />
                        <GradientStop Color="#00000000" Offset="0.5" />
                        <GradientStop Color="#40000000" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Grid>
    </controls:PedalCardBorder>
</UserControl>
