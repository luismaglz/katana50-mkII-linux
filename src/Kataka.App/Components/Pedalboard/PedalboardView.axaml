<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:pedalboard="using:Kataka.App.Components.Pedalboard"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="2400"
             d:DesignHeight="480"
             x:Class="Kataka.App.Views.PedalboardView"
             x:DataType="vm:AmpEditorViewModel"
             x:CompileBindings="False">
    <Border Classes="panel-section alt" Padding="18">
        <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <TextBlock Text="PEDALBOARD"
                           FontSize="18" FontWeight="Bold" LetterSpacing="1.5"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="CHAIN"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource KatanaSubtleTextBrush}" />
                    <ComboBox Classes="midi-port-picker"
                              MinWidth="130"
                              ItemsSource="{x:Static pedalboard:PedalboardViewModel.ChainPatternNames}"
                              SelectedIndex="{Binding Pedalboard.SelectedChainPattern, Mode=TwoWay}" />
                </StackPanel>
            </Grid>

            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Pedalboard.ChainNodes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Top" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.DataTemplates>

                        <!-- Input: card only, no left connector -->
                        <DataTemplate DataType="pedalboard:PedalboardInput">
                            <Border CornerRadius="10" Width="100" BorderThickness="2"
                                    BorderBrush="#3a5a6a"
                                    Background="{StaticResource TextLightBrush}"
                                    VerticalAlignment="Top">
                                <StackPanel Spacing="0" HorizontalAlignment="Center">
                                    <Border Width="96" Height="6" CornerRadius="10,10,0,0"
                                            Background="#607080" />
                                    <StackPanel Spacing="5" Margin="10,10,10,12" HorizontalAlignment="Center">
                                        <Image Source="/Assets/electric-guitar.png"
                                               Width="80" Height="80"
                                               HorizontalAlignment="Center" BlendMode="Multiply" />
                                        <TextBlock Text="INPUT"
                                                   FontSize="11" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#7ab0c8" LetterSpacing="1.2" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>

                        <!-- Output: left connector + speakers card -->
                        <DataTemplate DataType="pedalboard:PedalboardOutput">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                                <Canvas Width="28" Height="40" VerticalAlignment="Top" Margin="0,24,0,0">
                                    <Border Canvas.Left="0" Canvas.Top="14" Width="28" Height="4"
                                            CornerRadius="2" Background="#7a7060" />
                                    <Border Canvas.Left="0" Canvas.Top="12" Width="7" Height="8"
                                            CornerRadius="2" Background="#444" />
                                    <Border Canvas.Left="21" Canvas.Top="12" Width="7" Height="8"
                                            CornerRadius="2" Background="#444" />
                                </Canvas>
                                <Border CornerRadius="10" Width="100" BorderThickness="2"
                                        BorderBrush="#3a5a6a"
                                        Background="{StaticResource TextLightBrush}"
                                        VerticalAlignment="Top">
                                    <StackPanel Spacing="0" HorizontalAlignment="Center">
                                        <Border Width="96" Height="6" CornerRadius="10,10,0,0"
                                                Background="#607080" />
                                        <StackPanel Spacing="5" Margin="10,10,10,12" HorizontalAlignment="Center">
                                            <Image Source="/Assets/speakers.png"
                                                   Width="80" Height="80"
                                                   HorizontalAlignment="Center" />
                                            <TextBlock Text="OUTPUT"
                                                       FontSize="11" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#7ab0c8" LetterSpacing="1.2" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DataTemplate>

                        <!-- Amp: left connector + amp card -->
                        <DataTemplate DataType="pedalboard:PedalboardAmp">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                                <Canvas Width="28" Height="40" VerticalAlignment="Top" Margin="0,24,0,0">
                                    <Border Canvas.Left="0" Canvas.Top="14" Width="28" Height="4"
                                            CornerRadius="2" Background="#7a7060" />
                                    <Border Canvas.Left="0" Canvas.Top="12" Width="7" Height="8"
                                            CornerRadius="2" Background="#444" />
                                    <Border Canvas.Left="21" Canvas.Top="12" Width="7" Height="8"
                                            CornerRadius="2" Background="#444" />
                                </Canvas>
                                <Border Width="110" CornerRadius="10"
                                        BorderThickness="2" BorderBrush="#8b1c1c"
                                        Background="{StaticResource TextLightBrush}"
                                        VerticalAlignment="Top">
                                    <StackPanel Spacing="0">
                                        <Border Height="6" CornerRadius="10,10,0,0"
                                                Background="#c0392b" />
                                        <StackPanel Spacing="5" Margin="10,10,10,12" HorizontalAlignment="Center">
                                            <Image Source="/Assets/amplifier.png"
                                                   Width="80" Height="80"
                                                   HorizontalAlignment="Center" />
                                            <TextBlock Text="AMP" FontSize="13" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#e04040" LetterSpacing="2" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DataTemplate>

                        <!-- Pedal: left connector + ContentControl dispatched by ViewLocator -->
                        <DataTemplate DataType="pedalboard:PedalboardPedalBase">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                                <Canvas Width="28" Height="40" VerticalAlignment="Top" Margin="0,24,0,0">
                                    <Border Canvas.Left="0" Canvas.Top="14" Width="28" Height="4"
                                            CornerRadius="2" Background="#7a7060" />
                                    <Border Canvas.Left="0" Canvas.Top="12" Width="7" Height="8"
                                            CornerRadius="2" Background="#444" />
                                    <Border Canvas.Left="21" Canvas.Top="12" Width="7" Height="8"
                                            CornerRadius="2" Background="#444" />
                                </Canvas>
                                <ContentControl Content="{Binding ViewModel}" />
                            </StackPanel>
                        </DataTemplate>

                    </ItemsControl.DataTemplates>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Border>
</UserControl>
