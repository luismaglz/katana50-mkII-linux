<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:ptb="using:Kataka.App.Components.PhysicalToggleButton"
             x:Class="Kataka.App.Controls.PedalHeaderControl"
             x:DataType="vm:PedalViewModel"
             x:CompileBindings="False"
             ClipToBounds="False">

    <ptb:PhysicalToggleButtonView IsChecked="{Binding IsEnabled}"
                                  DisplayName="{Binding DisplayName}" />

</UserControl>
