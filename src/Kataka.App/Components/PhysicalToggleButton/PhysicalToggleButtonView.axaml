<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="using:Kataka.App.Components.PhysicalToggleButton"
             mc:Ignorable="d"
             d:DesignWidth="200" d:DesignHeight="60"
             d:DataContext="{x:Static local:DesignPhysicalToggleButtonViewModel.Instance}"
             x:Class="Kataka.App.Components.PhysicalToggleButton.PhysicalToggleButtonView"
             x:Name="Root"
             ClipToBounds="False">

    <UserControl.Styles>
        <Style Selector="ToggleButton.physical">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4,4,4,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="Root"
                            Background="#2A2E35"
                            CornerRadius="8"
                            Padding="14,7"
                            BoxShadow="0 3 6 0 #90000000, 0 1 0 0 #28FFFFFF">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.physical:checked /template/ Border#Root">
            <Setter Property="Background" Value="#1C1F25" />
            <Setter Property="BoxShadow" Value="inset 0 2 6 0 #55000000, inset 0 -1 2 0 #10FFFFFF" />
        </Style>
        <Style Selector="ToggleButton.physical:pointerover /template/ Border#Root">
            <Setter Property="Background" Value="#31363E" />
        </Style>
        <Style Selector="Border.LedBody">
            <Setter Property="Background" Value="#2A2A2A" />
        </Style>
        <Style Selector="ToggleButton:checked Border.LedBody">
            <Setter Property="Background" Value="#00e676" />
        </Style>
    </UserControl.Styles>

    <ToggleButton Classes="physical"
                  IsChecked="{Binding #Root.IsChecked, Mode=TwoWay}">

        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="{Binding #Root.DisplayName}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />

            <Panel Width="14" Height="14" VerticalAlignment="Center">
                <Border Width="14" Height="14" CornerRadius="7" Background="#111" />
                <Border Classes="LedBody"
                        Width="10" Height="10" CornerRadius="5"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Transitions>
                        <Transitions>
                            <BrushTransition Property="Background" Duration="0:0:0.1" />
                        </Transitions>
                    </Border.Transitions>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="2"
                                          Opacity="{Binding #Root.IsChecked}"
                                          Color="#00e676" />
                    </Border.Effect>
                </Border>
            </Panel>
        </StackPanel>
    </ToggleButton>

</UserControl>
