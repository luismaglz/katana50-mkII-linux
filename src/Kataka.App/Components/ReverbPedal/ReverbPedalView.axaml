<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kataka.App.ViewModels"
             xmlns:dvm="using:Kataka.App.ViewModels.Design"
             xmlns:controls="using:Kataka.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="300"
             d:DesignHeight="520"
             d:DataContext="{x:Static dvm:DesignReverbPedalViewModel.Instance}"
             x:Class="Kataka.App.Views.ReverbPedalView"
             x:DataType="vm:ReverbPedalViewModel"
             x:CompileBindings="False">

    <Border MinWidth="160" CornerRadius="8" VerticalAlignment="Top"
            Classes="pedal-card"
            Background="{Binding CardBackgroundBrush}">
        <Grid>
            <StackPanel Spacing="0">
                <!-- Reverb accent bar: purple -->
                <Border Height="6" CornerRadius="8,8,0,0" Background="#9b40e0" />
                <StackPanel Spacing="10" Margin="12,10,12,14">
                    <!-- On/Off toggle + LED -->
                    <controls:PedalHeaderControl />

                    <!-- Type selector -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="TYPE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#5a2088" />
                        <ComboBox Classes="midi-port-picker"
                                  HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding TypeOptions}"
                                  SelectedItem="{Binding SelectedTypeOption}" />
                    </StackPanel>


                    <!-- Row 1: Time, PreDelay, E.Level, D.Mix -->
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <controls:RotaryKnobV2 Label="TIME" Scale="0.75"
                                               Description="Adjusts the length (duration) of the reverberation."
                                               Minimum="0" Maximum="127"
                                               Value="{Binding Time}"
                                               LabelFontSize="12" />
                        <controls:RotaryKnobV2 Label="PRE DELAY" Scale="0.75"
                                               Description="Adjusts the time delay before the reverb sound appears (0–500 ms)."
                                               Minimum="0" Maximum="127"
                                               Value="{Binding PreDelay}"
                                               LabelFontSize="12" />
                        <controls:RotaryKnobV2 Label="E.LEVEL" Scale="0.75"
                                               Description="Adjusts the volume of the reverb (effect) sound."
                                               Minimum="0" Maximum="100"
                                               Value="{Binding EffectLevel}"
                                               LabelFontSize="12" />
                        <controls:RotaryKnobV2 Label="D.MIX" Scale="0.75"
                                               Description="Adjusts the volume of the direct (dry) sound."
                                               Minimum="0" Maximum="100"
                                               Value="{Binding DirectMix}"
                                               LabelFontSize="12" />
                    </StackPanel>

                    <!-- Row 2: LowCut, HighCut, Density, Color -->
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <controls:SteppedKnobV2 Label="LOW CUT" Scale="0.75"
                                                Description="Sets the frequency at which the low cut filter takes effect. At minimum (FLAT), the filter has no effect."
                                                Steps="{x:Static vm:FrequencySteps.LowCut18}"
                                                Value="{Binding LowCut}"
                                                LabelFontSize="12" />
                        <controls:SteppedKnobV2 Label="HIGH CUT" Scale="0.75"
                                                Description="Sets the frequency at which the high cut filter takes effect. At maximum (FLAT), the filter has no effect."
                                                Steps="{x:Static vm:FrequencySteps.HighCut18}"
                                                Value="{Binding HighCut}"
                                                LabelFontSize="12" />
                        <controls:RotaryKnobV2 Label="DENSITY" Scale="0.75"
                                               Description="Adjusts the density of the reverb sound."
                                               Minimum="0" Maximum="10"
                                               Value="{Binding Density}"
                                               LabelFontSize="12" />
                        <controls:RotaryKnobV2 Label="COLOR" Scale="0.75"
                                               Description="Adjusts the unique tone character of the spring reverb. Only active when TYPE is SPRING."
                                               Minimum="0" Maximum="100"
                                               Value="{Binding Color}"
                                               LabelFontSize="12" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <Border IsHitTestVisible="False" CornerRadius="8">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#33FFFFFF" Offset="0" />
                        <GradientStop Color="#00000000" Offset="0.5" />
                        <GradientStop Color="#40000000" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Grid>
    </Border>
</UserControl>
